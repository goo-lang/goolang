// divzero_probe (P1-7): integer divide-by-zero must abort, not silently
// return garbage. Compiled and run by the `divzero-probe` Makefile target,
// which asserts a non-zero exit and the "integer divide by zero" message.
package main

import "fmt"

func main() {
	a := 10
	b := 0
	c := a / b
	fmt.Println(c)
}
