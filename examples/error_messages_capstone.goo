package main
import (
	"fmt"
	"strconv"
)
func parse(s string) (int, error) {
	n, err := strconv.Atoi(s)
	if err != nil {
		return 0, fmt.Errorf("parse %s: %s", s, err.Error())
	}
	return n, nil
}
func main() {
	n, err := parse("42")
	if err != nil {
		fmt.Println(err.Error())
	} else {
		fmt.Println(n)
	}
	_, err2 := parse("bad")
	if err2 != nil {
		fmt.Println(err2.Error())
	}
}
