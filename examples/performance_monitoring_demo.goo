// Performance Monitoring Demo - Real-time Development Insights
package main

import "fmt"

// Example functions to demonstrate performance monitoring
func fibonacci(n: int) int {
    if n <= 1 {
        return n
    }
    return fibonacci(n-1) + fibonacci(n-2)
}

func matrixMultiply(a: [][]int, b: [][]int) [][]int {
    rows := len(a)
    cols := len(b[0])
    result := make([][]int, rows)
    
    for i := 0; i < rows; i++ {
        result[i] = make([]int, cols)
        for j := 0; j < cols; j++ {
            for k := 0; k < len(b); k++ {
                result[i][j] += a[i][k] * b[k][j]
            }
        }
    }
    
    return result
}

func heavyComputation() {
    // Simulate CPU-intensive work
    sum := 0
    for i := 0; i < 1000000; i++ {
        sum += i * i
    }
    fmt.Printf("Heavy computation result: %d\n", sum)
}

func memoryIntensiveOperation() []int {
    // Simulate memory-intensive work
    data := make([]int, 100000)
    for i := 0; i < len(data); i++ {
        data[i] = i * 2
    }
    return data
}

// Example usage with REPL performance monitoring:
/*
REPL Session Example:

