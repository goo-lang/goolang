  Reload Count: 1
  Average Reload Time: 156ms
  Memory Impact per Reload: +1.2MB
  Files Watched: 12

goo> // Test type-intensive operations
goo> :type fibonacci
func(int) int

goo> :type matrixMultiply
func([][]int, [][]int) [][]int

goo> :perf reset
Performance metrics reset.

goo> :perf status
Performance Monitor Status:
  Enabled: Yes
  Recording: Yes
  Sample Interval: 100 ms
  Current Memory: 47.1 MB
  CPU Usage: 3.8%
  Active Session: 2
  Total Sessions: 1
  Alerts Active: 0

goo> :exit
Performance summary:
  Session Duration: 342.5 seconds
  Total Operations: 8
  Peak Memory: 47.1 MB
  Average CPU: 15.2%
  Alerts Triggered: 1
Goodbye!
*/

func main() {
    fmt.Println("Run 'goo-repl' to start interactive session with performance monitoring!")
    fmt.Println("Try the expressions shown in the comments above.")
    fmt.Println("Use ':perf' commands to monitor performance in real-time.")
    
    // Example of programmatic performance monitoring usage
    fmt.Println("\nExample performance monitoring output:")
    fmt.Println("- Memory usage tracked during allocations")
    fmt.Println("- CPU usage monitored during computations")
    fmt.Println("- Compilation time measured for each expression")
    fmt.Println("- Alerts triggered for performance thresholds")
    fmt.Println("- Historical data available for analysis")
}