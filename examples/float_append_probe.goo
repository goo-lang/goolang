package main

import "fmt"

func main() {
	s := []float32{1.5}
	w := float64(2.5)
	s = append(s, w)
	fmt.Println(s[1] == float32(2.5))
	fmt.Println(s[0] == float32(1.5))
	t := []float64{0.25}
	n := float32(3.5)
	t = append(t, n)
	fmt.Println(t[1] == 3.5)
	fmt.Println(t[0] == 0.25)
	fmt.Println(len(s) + len(t))
}
