// divzero_abort_probe (P1-7): integer divide-by-zero must abort (non-zero
// exit + panic message), not return garbage. Migrated from the standalone
// `divzero-probe` Makefile target into the golden suite (Phase 0 Task 1) —
// see examples/divzero_abort_probe.exit (expected exit code, 134 today —
// SIGABRT; Task 6 flips panics to exit 2) and .stderr.txt (panic message
// substring).
package main

import "fmt"

func main() {
	a := 10
	b := 0
	c := a / b
	fmt.Println(c)
}
