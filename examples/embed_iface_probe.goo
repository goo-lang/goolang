package main

import "fmt"

type Greeter interface {
	Greet() string
}

type Base struct {
	Name string
}

func (b Base) Greet() string {
	return "hi " + b.Name
}

type English struct {
	Base
	Loud bool
}

type Direct struct {
	Word string
}

func (d Direct) Greet() string {
	return d.Word
}

func main() {
	gs := []Greeter{English{Base: Base{Name: "ann"}, Loud: true}, Direct{Word: "yo"}}
	for _, g := range gs {
		fmt.Println(g.Greet())
	}
}
