package main

import "fmt"

type Animal interface {
	Sound() string
}

type Dog struct {
	Name string
}

func (d Dog) Sound() string {
	return "woof"
}

type Cat struct {
	Lives int
}

func (c Cat) Sound() string {
	return "meow"
}

func main() {
	var a Animal = Dog{Name: "Rex"}
	d, ok := a.(Dog)
	fmt.Println(ok)
	fmt.Println(d.Name)
	c, ok2 := a.(Cat)
	fmt.Println(ok2)
	fmt.Println(c.Lives)
	d2 := a.(Dog)
	fmt.Println(d2.Sound())
}
