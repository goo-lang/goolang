package main
import "fmt"
func reader(p *int, done chan int) { done <- *p }
func spawnAll(xs []int, done chan int) {
    for _, v := range xs {
        go reader(&v, done)
    }
}
func makeSlice() []int {
    var s []int
    s = append(s, 5)
    s = append(s, 5)
    s = append(s, 5)
    return s
}
func main() {
    xs := makeSlice()
    d := make_chan(int, 3)
    spawnAll(xs, d)
    fmt.Println(<-d + <-d + <-d)
}
