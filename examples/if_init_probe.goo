package main

import "fmt"

func main() {
	m := map[string]int{"a": 1}
	if v, ok := m["a"]; ok {
		fmt.Println("has a", v)
	}
	if _, ok := m["z"]; ok {
		fmt.Println("has z")
	} else {
		fmt.Println("no z")
	}
	if x := 3 * 4; x > 10 {
		fmt.Println("big", x)
	} else {
		fmt.Println("small", x)
	}
}
