package main

import "fmt"

func Filter[T any](s []T, keep func(T) bool) []T {
	out := make([]T, 0, len(s))
	for _, v := range s {
		if keep(v) {
			out = append(out, v)
		}
	}
	return out
}

func main() {
	xs := []int{1, 2, 3, 4}
	ys := Filter(xs, func(x int) bool { return x%2 == 0 })
	fmt.Println(len(ys), ys[0], ys[1])
}
