// bounds_probe (P1-6): out-of-range slice index must abort, not read past the
// buffer. Run by the `bounds-probe` Makefile target, which asserts a non-zero
// exit and an "index out of range"/"bounds check failed" message.
package main

import "fmt"

func main() {
	s := [10, 20, 30]
	fmt.Println(s[5])
}
