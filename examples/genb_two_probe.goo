package main

import "fmt"

type Labeler interface {
	Label() int
}

type A struct{ x int }
func (a A) Label() int { return a.x + 1 }

type B struct{ y int }
func (b B) Label() int { return b.y * 10 }

func Show[T Labeler](v T) int { return v.Label() }

func main() {
	fmt.Println(Show(A{x: 5}))
	fmt.Println(Show(B{y: 5}))
}
