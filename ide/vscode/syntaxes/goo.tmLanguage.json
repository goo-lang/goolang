{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Goo",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#variables"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#error-unions"
    },
    {
      "include": "#nullable-types"
    },
    {
      "include": "#ownership-qualifiers"
    },
    {
      "include": "#channels"
    }
  ],
  "repository": {
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.goo",
          "match": "\\b(if|else|while|for|break|continue|return|defer|go|select|switch|case|default)\\b"
        },
        {
          "name": "keyword.declaration.goo",
          "match": "\\b(fn|let|var|const|struct|interface|enum|type|import|export|package)\\b"
        },
        {
          "name": "keyword.modifier.goo",
          "match": "\\b(pub|priv|mut|unsafe|extern|inline)\\b"
        },
        {
          "name": "keyword.operator.goo",
          "match": "\\b(and|or|not|in)\\b"
        },
        {
          "name": "keyword.other.goo",
          "match": "\\b(go|select|void|try|catch|match)\\b"
        },
        {
          "name": "constant.language.goo",
          "match": "\\b(true|false|null)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.goo",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.goo",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.goo",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.goo",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.goo",
          "match": "//.*$"
        },
        {
          "name": "comment.block.goo",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.decimal.goo",
          "match": "\\b([0-9]+\\.?[0-9]*)\\b"
        },
        {
          "name": "constant.numeric.hex.goo",
          "match": "\\b0[xX][0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.binary.goo",
          "match": "\\b0[bB][01]+\\b"
        },
        {
          "name": "constant.numeric.octal.goo",
          "match": "\\b0[oO][0-7]+\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.goo",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.numeric.goo",
          "match": "\\b(int|int8|int16|int32|int64|uint|uint8|uint16|uint32|uint64|float|float32|float64)\\b"
        },
        {
          "name": "storage.type.other.goo",
          "match": "\\b(bool|string|char)\\b"
        },
        {
          "name": "storage.type.channel.goo",
          "match": "\\bchan\\b"
        },
        {
          "name": "storage.type.custom.goo",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.declaration.goo",
          "begin": "\\b(let|var|const)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "beginCaptures": {
            "1": {
              "name": "keyword.declaration.goo"
            },
            "2": {
              "name": "variable.name.goo"
            }
          },
          "end": "(?=;|=|\\n)"
        }
      ]
    },
    "error-unions": {
      "patterns": [
        {
          "name": "storage.type.error-union.goo",
          "match": "!([a-zA-Z_][a-zA-Z0-9_]*|\\[[^\\]]*\\]|\\([^)]*\\))",
          "captures": {
            "1": {
              "name": "storage.type.goo"
            }
          }
        },
        {
          "name": "keyword.control.error.goo",
          "match": "\\berror\\b"
        }
      ]
    },
    "nullable-types": {
      "patterns": [
        {
          "name": "storage.type.nullable.goo",
          "match": "\\?([a-zA-Z_][a-zA-Z0-9_]*|\\[[^\\]]*\\]|\\([^)]*\\))",
          "captures": {
            "1": {
              "name": "storage.type.goo"
            }
          }
        }
      ]
    },
    "ownership-qualifiers": {
      "patterns": [
        {
          "name": "storage.modifier.ownership.goo",
          "match": "\\b(owned|borrowed|shared|move|copy)\\b"
        }
      ]
    },
    "channels": {
      "patterns": [
        {
          "name": "storage.type.channel.goo",
          "match": "\\bchan\\s+([a-zA-Z_][a-zA-Z0-9_]*|\\[[^\\]]*\\]|\\([^)]*\\))",
          "captures": {
            "1": {
              "name": "storage.type.goo"
            }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arithmetic.goo",
          "match": "\\+|\\-|\\*|\\/|\\%|\\+\\+|\\-\\-"
        },
        {
          "name": "keyword.operator.comparison.goo",
          "match": "==|!=|<|>|<=|>=|<=>|\\?"
        },
        {
          "name": "keyword.operator.logical.goo",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.bitwise.goo",
          "match": "&|\\||\\^|~|<<|>>"
        },
        {
          "name": "keyword.operator.assignment.goo",
          "match": "=|\\+=|\\-=|\\*=|\\/=|\\%=|&=|\\|=|\\^=|<<=|>>="
        },
        {
          "name": "keyword.operator.channel.goo",
          "match": "<-"
        },
        {
          "name": "keyword.operator.reference.goo",
          "match": "&|\\*"
        },
        {
          "name": "keyword.operator.other.goo",
          "match": "\\.|->|::|\\?|!"
        }
      ]
    }
  },
  "scopeName": "source.goo"
}