// Pattern Matching Test
// Demonstrates all pattern matching features in Goo

package main

// Test basic literal patterns
func test_literal_patterns() {
    var value int = 42
    
    match value {
        case 0:
            println("Zero")
        case 42:
            println("The answer to everything")
        case 100:
            println("Century")
        default:
            println("Something else")
    }
}

// Test variable binding patterns
func test_variable_binding() {
    var value int = 123
    
    match value {
        case 0:
            println("Zero")
        case n if n < 0:
            println("Negative:", n)
        case n if n > 0 && n < 10:
            println("Small positive:", n)
        case n:
            println("Large positive:", n)
    }
}

// Test wildcard patterns
func test_wildcard_patterns() {
    var value int = 999
    
    match value {
        case 0:
            println("Zero")
        case 1:
            println("One")
        case _:
            println("Anything else")
    }
}

// Test error union pattern matching
func readFile(path string) ![]byte {
    // Mock implementation
    if path == "nonexistent" {
        return error("File not found")
    }
    return []byte("file content")
}

func test_error_union_patterns() {
    result := readFile("test.txt")
    
    match result {
        case err: Error:
            println("Error occurred:", err)
        case data: []byte:
            println("File content:", string(data))
    }
}

// Test nullable type patterns
func getName(id int) ?string {
    if id == 1 {
        return "Alice"
    }
    return nil
}

func test_nullable_patterns() {
    name := getName(1)
    
    match name {
        case nil:
            println("No name found")
        case n: string:
            println("Name is:", n)
    }
}

// Test guard conditions
func test_guard_conditions() {
    var age int = 25
    
    match age {
        case n if n < 13:
            println("Child")
        case n if n >= 13 && n < 20:
            println("Teenager")
        case n if n >= 20 && n < 60:
            println("Adult")
        case n if n >= 60:
            println("Senior")
        default:
            println("Unknown age category")
    }
}

