}

// Example of hardware abstraction
func write_port_byte(port uint16, value uint8) {
    unsafe {
        // x86 port I/O
        asm {"mov %0, %%dx; mov %1, %%al; outb %%al, %%dx" : : "r"(port), "r"(value) : "dx", "al"}
    }
}

func read_port_byte(port uint16) uint8 {
    var result uint8
    unsafe {
        // x86 port I/O  
        asm {"mov %1, %%dx; inb %%dx, %%al; mov %%al, %0" : "=r"(result) : "r"(port) : "dx", "al"}
    }
    return result
}