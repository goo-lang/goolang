/// Test real-world configuration loading scenario
fn test_config_loading_scenario() !void {
    fmt.println("\n🏗️  Testing Configuration Loading Scenario");
    fmt.println("------------------------------------------");
    
    let transformer = get_global_error_transformer();
    if !transformer {
        return fmt.error("Failed to get global transformer");
    }
    
    // Simulate configuration loading with various errors
    let config_errors: []StructuredError* = [];
    
    // File not found error
    let file_error = SystemError.FileSystemError(
        errno: 2,
        syscall: "open",
        path: "/etc/app/config.toml",
        permission_bits: 644
    );
    config_errors.append(file_error);
    
    // Permission denied error
    let perm_error = SystemError.FileSystemError(
        errno: 13,
        syscall: "read",
        path: "/etc/app/secrets.conf",
        permission_bits: 600
    );
    config_errors.append(perm_error);
    
    fmt.println("Simulated configuration loading errors:");
    
    // Transform each error to user-friendly format
    for i, system_error in config_errors {
        // Convert to user error
        let user_error = error_transformer_convert(
            transformer,
            system_error,
            error_type_find_by_name("UserError")
        );
        
        if user_error {
            let user_msg = error_transformer_generate_localized_message(
                transformer,
                user_error,
                ERROR_LANG_EN,
                "user"
            );
            
            let recovery_msg = error_transformer_generate_localized_message(
                transformer,
                user_error,
                ERROR_LANG_EN,
                "recovery"
            );
            
            fmt.println("  Error {}: {}", i + 1, user_msg ? user_msg : "[no message]");
            fmt.println("    Recovery: {}", recovery_msg ? recovery_msg : "[no suggestion]");
            
            if user_msg free(user_msg);
            if recovery_msg free(recovery_msg);
            structured_error_free(user_error);
        }
    }
    
    fmt.println("✅ Configuration loading scenario completed");
    
    // Clean up
    for error in config_errors {
        structured_error_free(error);
    }
}

