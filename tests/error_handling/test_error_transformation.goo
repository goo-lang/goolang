/// Test file for error transformation and internationalization system
/// Demonstrates automatic error conversion, message generation, and localization

package main

import (
    "fmt"
    "testing"
    "time"
    "http"
    "fs"
    "database"
)

// =============================================================================
// Error Type Definitions for Testing
// =============================================================================

/// Technical system errors (internal use)
@error_hierarchy
enum SystemError {
    FileSystemError(
        errno: int,
        syscall: string,
        path: string,
        permission_bits: int
    ),
    NetworkError(
        socket_fd: int,
        errno: int,
        local_addr: string,
        remote_addr: string,
        bytes_transferred: int
    ),
    DatabaseError(
        connection_id: string,
        query_hash: string,
        error_code: int,
        sqlstate: string,
        execution_time_ms: int
    )
}

/// User-friendly errors (for end users)
@error_hierarchy
enum UserError {
    ConfigurationProblem(
        issue_description: string,
        suggested_fix: string,
        help_url: string
    ),
    ConnectionProblem(
        service_name: string,
        retry_in_seconds: int,
        is_temporary: bool
    ),
    DataProblem(
        operation: string,
        data_type: string,
        suggestion: string
    )
}

/// API errors (for machine consumption)
@error_hierarchy
enum APIError {
    BadRequest(
        error_code: int,
        field_errors: []string,
        request_id: string
    ),
    ServiceUnavailable(
        error_code: int,
        retry_after_seconds: int,
        maintenance_window: string
    ),
    DataError(
        error_code: int,
        validation_errors: []string,
        affected_resources: []string
    )
}

// =============================================================================
// Error Transformation Test Functions
// =============================================================================

/// Test automatic error type conversion
fn test_error_conversion() !void {
    fmt.println("🔄 Testing Error Type Conversion");
    fmt.println("--------------------------------");
    
    // Initialize transformation system
    error_transformation_system_init();
    defer error_transformation_system_shutdown();
    
    let transformer = get_global_error_transformer();
    if !transformer {
        return fmt.error("Failed to get global transformer");
    }
    
    // Create a technical system error
    let system_error = SystemError.FileSystemError(
        errno: 2,
        syscall: "open",
        path: "/etc/nonexistent.conf",
        permission_bits: 644
    );
    
    // Convert to user-friendly error
    let user_error = try error_transformer_convert(
        transformer,
        system_error,
        error_type_find_by_name("UserError")
    ) catch |err| {
        return fmt.error("Conversion failed: {}", err.message);
    };
    
    // Verify conversion worked
    if user_error.type_def.name != "UserError" {
        return fmt.error("Conversion produced wrong type: {}", user_error.type_def.name);
    }
    
    fmt.println("✅ System error converted to user error successfully");
    
    // Test conversion to API error
    let api_error = try error_transformer_convert(
        transformer,
        system_error,
        error_type_find_by_name("APIError")
    ) catch |err| {
        return fmt.error("API conversion failed: {}", err.message);
    };
    
    if api_error.type_def.name != "APIError" {
        return fmt.error("API conversion produced wrong type: {}", api_error.type_def.name);
    }
    
    fmt.println("✅ System error converted to API error successfully");
    
    // Test conversion compatibility check
    let can_convert = error_transformer_can_convert(
        transformer,
        system_error,
        error_type_find_by_name("UserError")
    );
    
    if !can_convert {
        return fmt.error("Compatibility check failed for valid conversion");
    }
    
    fmt.println("✅ Conversion compatibility check passed");
    
    // Clean up
    structured_error_free(user_error);
    structured_error_free(api_error);
    structured_error_free(system_error);
}

/// Test message generation with different contexts
fn test_message_generation() !void {
    fmt.println("\n📝 Testing Message Generation");
    fmt.println("-----------------------------");
    
    let transformer = get_global_error_transformer();
    if !transformer {
        return fmt.error("Failed to get global transformer");
    }
    
    // Create a network error for testing
    let network_error = SystemError.NetworkError(
        socket_fd: 5,
        errno: 110,
        local_addr: "127.0.0.1:8080",
        remote_addr: "api.example.com:443",
        bytes_transferred: 0
    );
    
    // Generate different types of messages
    let short_msg = error_transformer_generate_localized_message(
        transformer,
        network_error,
        ERROR_LANG_EN,
        "short"
    );
    
    let detailed_msg = error_transformer_generate_localized_message(
        transformer,
        network_error,
        ERROR_LANG_EN,
        "detailed"
    );
    
    let user_msg = error_transformer_generate_localized_message(
        transformer,
        network_error,
        ERROR_LANG_EN,
        "user"
    );
    
    let technical_msg = error_transformer_generate_localized_message(
        transformer,
        network_error,
        ERROR_LANG_EN,
        "technical"
    );
    
    let recovery_msg = error_transformer_generate_localized_message(
        transformer,
        network_error,
        ERROR_LANG_EN,
        "recovery"
    );
    
    // Verify messages were generated
    if !short_msg || strlen(short_msg) == 0 {
        return fmt.error("Short message generation failed");
    }
    
    if !detailed_msg || strlen(detailed_msg) == 0 {
        return fmt.error("Detailed message generation failed");
    }
    
    fmt.println("Generated Messages:");
    fmt.println("  Short:     {}", short_msg);
    fmt.println("  Detailed:  {}", detailed_msg);
    fmt.println("  User:      {}", user_msg);
    fmt.println("  Technical: {}", technical_msg);
    fmt.println("  Recovery:  {}", recovery_msg);
    
    fmt.println("✅ Message generation successful");
    
    // Test contextual message generation
    let cli_context = error_localization_context_new(ERROR_LANG_EN, "en_US");
    cli_context.use_formal_language = false;
    
    let cli_msg = error_transformer_generate_contextual_message(
        transformer,
        network_error,
        "cli",
        cli_context
    );
    
    let web_msg = error_transformer_generate_contextual_message(
        transformer,
        network_error,
        "web",
        cli_context
    );
    
    let api_msg = error_transformer_generate_contextual_message(
        transformer,
        network_error,
        "api",
        cli_context
    );
    
    fmt.println("\nContextual Messages:");
    fmt.println("  CLI: {}", cli_msg ? cli_msg : "[null]");
    fmt.println("  Web: {}", web_msg ? web_msg : "[null]");
    fmt.println("  API: {}", api_msg ? api_msg : "[null]");
    
    fmt.println("✅ Contextual message generation successful");
    
    // Clean up
    free(short_msg);
    free(detailed_msg);
    free(user_msg);
    free(technical_msg);
    free(recovery_msg);
    free(cli_msg);
    free(web_msg);
    free(api_msg);
    error_localization_context_free(cli_context);
    structured_error_free(network_error);
}

/// Test internationalization with multiple languages
fn test_internationalization() !void {
    fmt.println("\n🌍 Testing Internationalization");
    fmt.println("------------------------------");
    
    let transformer = get_global_error_transformer();
    if !transformer {
        return fmt.error("Failed to get global transformer");
    }
    
    // Create a database error for testing
    let db_error = SystemError.DatabaseError(
        connection_id: "conn_123",
        query_hash: "a1b2c3d4",
        error_code: 1062,
        sqlstate: "23000",
        execution_time_ms: 150
    );
    
    // Test different languages
    let languages = [ERROR_LANG_EN, ERROR_LANG_ES, ERROR_LANG_FR, ERROR_LANG_DE];
    let language_names = ["English", "Spanish", "French", "German"];
    
    fmt.println("Error messages in different languages:");
    
    for i, language in languages {
        let msg = error_transformer_generate_localized_message(
            transformer,
            db_error,
            language,
            "user"
        );
        
        fmt.println("  {} ({}): {}", 
                   language_names[i], 
                   error_language_to_string(language),
                   msg ? msg : "[translation not available]");
        
        if msg {
            free(msg);
        }
    }
    
    // Test locale-specific formatting
    let us_context = error_localization_context_new(ERROR_LANG_EN, "en_US");
    us_context.date_format = "%m/%d/%Y";
    us_context.time_format = "%I:%M:%S %p";
    us_context.number_format = "%.2f";
    
    let uk_context = error_localization_context_new(ERROR_LANG_EN, "en_GB");
    uk_context.date_format = "%d/%m/%Y";
    uk_context.time_format = "%H:%M:%S";
    uk_context.number_format = "%.2f";
    
    let us_msg = error_transformer_generate_message(transformer, db_error, us_context, "detailed");
    let uk_msg = error_transformer_generate_message(transformer, db_error, uk_context, "detailed");
    
    fmt.println("\nLocale-specific formatting:");
    fmt.println("  US English: {}", us_msg ? us_msg : "[null]");
    fmt.println("  UK English: {}", uk_msg ? uk_msg : "[null]");
    
    fmt.println("✅ Internationalization test completed");
    
    // Clean up
    if us_msg free(us_msg);
    if uk_msg free(uk_msg);
    error_localization_context_free(us_context);
    error_localization_context_free(uk_context);
    structured_error_free(db_error);
}

/// Test machine-readable error codes
fn test_error_codes() !void {
    fmt.println("\n🔢 Testing Machine-Readable Error Codes");
    fmt.println("---------------------------------------");
    
    // Get the global error code registry
    let registry = get_global_error_code_registry();
    if !registry {
        return fmt.error("Failed to get global error code registry");
    }
    
    // Register some test error codes
    let file_not_found_code = error_code_register(
        registry,
        2001,
        ERROR_CODE_CLASS_CONFIG,
        "CONFIG_FILE_NOT_FOUND",
        "filesystem",
        ERROR_SEVERITY_ERROR
    );
    
    let network_timeout_code = error_code_register(
        registry,
        3001,
        ERROR_CODE_CLASS_NETWORK,
        "NETWORK_CONNECTION_TIMEOUT",
        "network",
        ERROR_SEVERITY_ERROR
    );
    
    let db_constraint_code = error_code_register(
        registry,
        4001,
        ERROR_CODE_CLASS_DATABASE,
        "DATABASE_CONSTRAINT_VIOLATION",
        "database",
        ERROR_SEVERITY_ERROR
    );
    
    if !file_not_found_code || !network_timeout_code || !db_constraint_code {
        return fmt.error("Failed to register error codes");
    }
    
    fmt.println("Registered error codes:");
    fmt.println("  {} ({}): {}", 
               file_not_found_code.code,
               file_not_found_code.identifier,
               file_not_found_code.category);
    fmt.println("  {} ({}): {}", 
               network_timeout_code.code,
               network_timeout_code.identifier,
               network_timeout_code.category);
    fmt.println("  {} ({}): {}", 
               db_constraint_code.code,
               db_constraint_code.identifier,
               db_constraint_code.category);
    
    // Test error code lookup
    let found_by_code = error_code_find_by_code(registry, 2001);
    let found_by_identifier = error_code_find_by_identifier(registry, "NETWORK_CONNECTION_TIMEOUT");
    
    if !found_by_code {
        return fmt.error("Failed to find error code by number");
    }
    
    if !found_by_identifier {
        return fmt.error("Failed to find error code by identifier");
    }
    
    if found_by_code.code != 2001 {
        return fmt.error("Wrong error code found: expected 2001, got {}", found_by_code.code);
    }
    
    if strcmp(found_by_identifier.identifier, "NETWORK_CONNECTION_TIMEOUT") != 0 {
        return fmt.error("Wrong error code found: expected NETWORK_CONNECTION_TIMEOUT, got {}", 
                        found_by_identifier.identifier);
    }
    
    fmt.println("✅ Error code registration and lookup successful");
    
    // Test associating error codes with structured types
    let system_error_type = error_type_find_by_name("SystemError");
    if system_error_type {
        error_code_associate_structured_type(
            file_not_found_code,
            system_error_type,
            "FileSystemError"
        );
        
        if file_not_found_code.structured_type == system_error_type {
            fmt.println("✅ Error code association with structured type successful");
        } else {
            return fmt.error("Error code association failed");
        }
    }
}

/// Test error transformation chains
fn test_transformation_chains() !void {
    fmt.println("\n🔗 Testing Error Transformation Chains");
    fmt.println("--------------------------------------");
    
    let transformer = get_global_error_transformer();
    if !transformer {
        return fmt.error("Failed to get global transformer");
    }
    
    // Create a complex system error
    let complex_error = SystemError.DatabaseError(
        connection_id: "prod_db_001",
        query_hash: "complex_join_abc123",
        error_code: 1205,
        sqlstate: "40001",
        execution_time_ms: 30000
    );
    
    // Create transformation chain to convert to user error
    let user_error_type = error_type_find_by_name("UserError");
    if !user_error_type {
        return fmt.error("Could not find UserError type");
    }
    
    let transformation_chain = error_transformer_create_chain(
        transformer,
        complex_error,
        user_error_type
    );
    
    if !transformation_chain {
        fmt.println("⚠️  No transformation chain available (expected for test scenario)");
        structured_error_free(complex_error);
        return;
    }
    
    fmt.println("Transformation chain created:");
    fmt.println("  Chain length: {}", transformation_chain.chain_length);
    fmt.println("  Total cost: {:.3f}", transformation_chain.total_cost);
    
    // Display the transformation chain
    for i in 0..transformation_chain.chain_length {
        let error = transformation_chain.errors[i];
        let rule = transformation_chain.rules_used[i];
        
        fmt.println("  Step {}: {} -> {} (cost: {:.3f})",
                   i + 1,
                   error.type_def.name,
                   rule ? rule.target_type.name : "unknown",
                   rule ? rule.conversion_cost : 0.0);
    }
    
    fmt.println("✅ Transformation chain test completed");
    
    // Clean up
    error_transformation_chain_free(transformation_chain);
    structured_error_free(complex_error);
}

/// Test batch error transformation
fn test_batch_transformation() !void {
    fmt.println("\n📦 Testing Batch Error Transformation");
    fmt.println("------------------------------------");
    
    let transformer = get_global_error_transformer();
    if !transformer {
        return fmt.error("Failed to get global transformer");
    }
    
    // Create multiple system errors
    let errors: []StructuredError* = [
        SystemError.FileSystemError(
            errno: 2,
            syscall: "open",
            path: "/etc/config1.conf",
            permission_bits: 644
        ),
        SystemError.FileSystemError(
            errno: 13,
            syscall: "read",
            path: "/root/secret.conf",
            permission_bits: 600
        ),
        SystemError.NetworkError(
            socket_fd: 3,
            errno: 111,
            local_addr: "0.0.0.0:8080",
            remote_addr: "service.example.com:443",
            bytes_transferred: 0
        ),
        SystemError.DatabaseError(
            connection_id: "batch_conn_001",
            query_hash: "batch_query_xyz",
            error_code: 2006,
            sqlstate: "08S01",
            execution_time_ms: 5000
        )
    ];
    
    fmt.println("Created {} system errors for batch transformation", errors.length);
    
    // Convert all to user errors
    let user_error_type = error_type_find_by_name("UserError");
    if !user_error_type {
        return fmt.error("Could not find UserError type");
    }
    
    let converted_errors: []StructuredError* = [];
    let converted_count = error_transformer_batch_convert(
        transformer,
        errors.data,
        errors.length,
        user_error_type,
        &converted_errors
    );
    
    fmt.println("Batch conversion results:");
    fmt.println("  Input errors: {}", errors.length);
    fmt.println("  Successfully converted: {}", converted_count);
    fmt.println("  Conversion rate: {:.1f}%", 
               (double)converted_count * 100.0 / errors.length);
    
    // Display converted errors
    for i in 0..converted_count {
        let original = errors[i];
        let converted = converted_errors[i];
        
        fmt.println("  {}: {} -> {}",
                   i + 1,
                   original.type_def.name,
                   converted ? converted.type_def.name : "[failed]");
    }
    
    fmt.println("✅ Batch transformation test completed");
    
    // Clean up
    for i in 0..errors.length {
        structured_error_free(errors[i]);
    }
    
    for i in 0..converted_count {
        if converted_errors[i] {
            structured_error_free(converted_errors[i]);
        }
    }
    free(converted_errors);
}

/// Test error similarity analysis
fn test_error_similarity() !void {
    fmt.println("\n🔍 Testing Error Similarity Analysis");
    fmt.println("-----------------------------------");
    
    let transformer = get_global_error_transformer();
    if !transformer {
        return fmt.error("Failed to get global transformer");
    }
    
    // Create similar errors
    let error1 = SystemError.FileSystemError(
        errno: 2,
        syscall: "open",
        path: "/etc/config.conf",
        permission_bits: 644
    );
    
    let error2 = SystemError.FileSystemError(
        errno: 2,
        syscall: "open",
        path: "/etc/app.conf",
        permission_bits: 644
    );
    
    let error3 = SystemError.NetworkError(
        socket_fd: 5,
        errno: 110,
        local_addr: "127.0.0.1:8080",
        remote_addr: "api.example.com:443",
        bytes_transferred: 0
    );
    
    // Calculate similarity scores
    let similarity_1_2 = error_transformer_calculate_similarity(error1, error2);
    let similarity_1_3 = error_transformer_calculate_similarity(error1, error3);
    let similarity_2_3 = error_transformer_calculate_similarity(error2, error3);
    
    fmt.println("Error similarity analysis:");
    fmt.println("  FileSystem vs FileSystem (similar): {:.3f}", similarity_1_2);
    fmt.println("  FileSystem vs Network:               {:.3f}", similarity_1_3);
    fmt.println("  FileSystem vs Network:               {:.3f}", similarity_2_3);
    
    // Similar errors should have higher similarity
    if similarity_1_2 <= similarity_1_3 {
        fmt.println("⚠️  Warning: Similar errors don't have higher similarity score");
    } else {
        fmt.println("✅ Similar errors correctly identified");
    }
    
    // Test smart error classification
    let classified_type = error_transformer_classify_error(
        transformer,
        "File not found: /etc/missing.conf",
        "configuration loading"
    );
    
    if classified_type {
        fmt.println("Smart classification result: {}", classified_type.name);
        fmt.println("✅ Error classification successful");
    } else {
        fmt.println("⚠️  Error classification returned no result");
    }
    
    // Clean up
    structured_error_free(error1);
    structured_error_free(error2);
    structured_error_free(error3);
}

