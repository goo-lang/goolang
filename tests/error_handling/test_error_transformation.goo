    structured_error_free(api_error);
    structured_error_free(db_error);
}

// =============================================================================
// Performance and Statistics Tests
// =============================================================================

/// Test transformation performance
fn test_transformation_performance() !void {
    fmt.println("\n⚡ Testing Transformation Performance");
    fmt.println("-----------------------------------");
    
    let transformer = get_global_error_transformer();
    if !transformer {
        return fmt.error("Failed to get global transformer");
    }
    
    let start_time = time.now_ms();
    let iterations = 1000;
    let successful_conversions = 0;
    let successful_messages = 0;
    
    fmt.println("Running {} transformation iterations...", iterations);
    
    for i in 0..iterations {
        // Create a test error
        let test_error = SystemError.NetworkError(
            socket_fd: i % 10,
            errno: 110,
            local_addr: "127.0.0.1:8080",
            remote_addr: "test.example.com:443",
            bytes_transferred: i * 100
        );
        
        // Try conversion (may not always succeed in test environment)
        let converted = error_transformer_convert(
            transformer,
            test_error,
            error_type_find_by_name("UserError")
        );
        
        if converted {
            successful_conversions++;
            
            // Generate message
            let msg = error_transformer_generate_localized_message(
                transformer,
                converted,
                ERROR_LANG_EN,
                "user"
            );
            
            if msg {
                successful_messages++;
                free(msg);
            }
            
            structured_error_free(converted);
        }
        
        structured_error_free(test_error);
    }
    
    let end_time = time.now_ms();
    let duration_ms = end_time - start_time;
    
    fmt.println("Performance Results:");
    fmt.println("  Total iterations:        {}", iterations);
    fmt.println("  Successful conversions:  {}", successful_conversions);
    fmt.println("  Successful messages:     {}", successful_messages);
    fmt.println("  Total time:              {} ms", duration_ms);
    
    if duration_ms > 0 {
        fmt.println("  Conversions per second:  {:.1f}", 
                   (double)successful_conversions * 1000.0 / duration_ms);
        fmt.println("  Messages per second:     {:.1f}", 
                   (double)successful_messages * 1000.0 / duration_ms);
    }
    
    fmt.println("✅ Performance test completed");
}

/// Print comprehensive statistics
fn test_statistics_reporting() !void {
    fmt.println("\n📊 Error Transformation Statistics");
    fmt.println("==================================");
    
    // Print detailed performance report
    print_error_transformation_performance_report();
    
    fmt.println("\n✅ Statistics reporting completed");
}

