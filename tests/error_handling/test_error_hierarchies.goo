// =============================================================================
// Supporting Types
// =============================================================================

struct ApplicationConfig {
    app_name: string,
    version: string,
    database: DatabaseConfig,
    api_endpoints: []string,
    auth: AuthConfig,
    business_logic: BusinessLogicConfig
}

struct DatabaseConfig {
    host: string,
    port: int,
    database_name: string,
    username: string
}

struct AuthConfig {
    method: string,
    token_expiry_seconds: int
}

struct BusinessLogicConfig {
    max_transaction_amount: float,
    daily_limit: float
}

struct UserData {
    id: string,
    name: string,
    email: string
}

struct TransferResult {
    transaction_id: string,
    from_account: string,
    to_account: string,
    amount: float,
    timestamp: string
}

struct ProcessingResult {
    successful_files: []string,
    failed_files: map[string]StructuredError
}

enum RecoveryAction {
    Retry,
    RetryWithBackoff(multiplier: float),
    RetryWithJitter(max_delay_ms: int),
    ShowEditor(line: int, column: int),
    PromptForCorrection(field: string, expected_format: string),
    CheckServiceHealth(host: string, port: int),
    TryAlternateDNS,
    CheckDatabaseHealth,
    Abort,
    SuggestTopUp(amount: float),
    FollowTransitionPath(steps: []string),
    ResetToInitialState,
    RefreshSession,
    RequestPermissionElevation(permission: string),
    LogAndContinue
}