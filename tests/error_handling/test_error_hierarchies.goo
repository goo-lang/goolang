}

// =============================================================================
// Test Helper Functions  
// =============================================================================

fn test_error_type_registration() {
    // Register error types programmatically
    let config_error_type = error_type_define("ConfigError", "Configuration-related errors");
    let file_not_found_variant = error_type_add_variant(config_error_type, "FileNotFound", "Configuration file not found", 1001);
    
    error_variant_add_string_field(file_not_found_variant, "path", "Path to the missing file", true);
    
    let parse_error_variant = error_type_add_variant(config_error_type, "ParseError", "Configuration parsing failed", 1002);
    error_variant_add_int_field(parse_error_variant, "line", "Line number of parse error", true, 1, 1000000);
    error_variant_add_int_field(parse_error_variant, "column", "Column number of parse error", true, 1, 1000);
    error_variant_add_string_field(parse_error_variant, "message", "Parse error message", true);
    
    print_error_type_definition(config_error_type);
    
    fmt.println("   ✅ Error type registration successful");
}

fn test_structured_error_creation() {
    let config_error_type = error_type_find_by_name("ConfigError");
    if !config_error_type {
        fmt.println("   ❌ ConfigError type not found");
        return;
    }
    
    // Create a structured error
    let error = structured_error_new(config_error_type, "FileNotFound");
    if !error {
        fmt.println("   ❌ Failed to create structured error");
        return;
    }
    defer structured_error_free(error);
    
    // Set field values
    structured_error_set_string_field(error, "path", "/etc/missing-config.toml");
    
    // Validate and finalize
    if structured_error_validate(error) {
        structured_error_finalize(error);
        print_structured_error(error);
        fmt.println("   ✅ Structured error creation successful");
    } else {
        fmt.println("   ❌ Structured error validation failed");
    }
}

fn test_error_inheritance() {
    // Create base and derived error types
    let base_error = error_type_define("IOError", "Base I/O error type");
    base_error.is_abstract = true;
    
    let fs_error = error_type_define("FileSystemError", "File system error type");
    error_type_set_parent(fs_error, base_error);
    
    // Test inheritance relationship
    if error_type_is_subtype_of(fs_error, base_error) {
        fmt.println("   ✅ Inheritance relationship established");
    } else {
        fmt.println("   ❌ Inheritance relationship failed");
    }
    
    // Test ancestor lookup
    let ancestor_count = 0;
    let ancestors = error_type_get_ancestors(fs_error, &ancestor_count);
    if ancestors && ancestor_count > 0 {
        fmt.println("   ✅ Found {} ancestors", ancestor_count);
        free(ancestors);
    } else {
        fmt.println("   ❌ Ancestor lookup failed");
    }
}

fn test_error_pattern_matching() {
    // Create various patterns
    let config_error_type = error_type_find_by_name("ConfigError");
    if !config_error_type {
        fmt.println("   ❌ ConfigError type not found for pattern matching");
        return;
    }
    
    let type_pattern = error_match_pattern_new_type(config_error_type, false);
    let severity_pattern = error_match_pattern_new_severity(ERROR_SEVERITY_ERROR, ERROR_SEVERITY_FATAL);
    
    // Create test error
    let error = structured_error_new(config_error_type, "FileNotFound");
    if error {
        structured_error_set_string_field(error, "path", "/test/path");
        structured_error_finalize(error);
        
        // Test pattern matching
        if structured_error_matches_pattern(error, type_pattern) {
            fmt.println("   ✅ Type pattern matching successful");
        } else {
            fmt.println("   ❌ Type pattern matching failed");
        }
        
        if structured_error_matches_pattern(error, severity_pattern) {
            fmt.println("   ✅ Severity pattern matching successful");
        } else {
            fmt.println("   ❌ Severity pattern matching failed");
        }
        
        structured_error_free(error);
    }
    
    error_match_pattern_free(type_pattern);
    error_match_pattern_free(severity_pattern);
}

fn test_error_aggregation_integration() {
    let aggregator = error_aggregator_new(AGGREGATOR_CONTINUE);
    if !aggregator {
        fmt.println("   ❌ Failed to create error aggregator");
        return;
    }
    defer error_aggregator_free(aggregator);
    
    // Create multiple structured errors and add to aggregator
    let config_error_type = error_type_find_by_name("ConfigError");
    if config_error_type {
        for i in 0..3 {
            let error = structured_error_new(config_error_type, "FileNotFound");
            if error {
                let path = fmt.sprintf("/config/file%d.toml", i);
                structured_error_set_string_field(error, "path", path);
                structured_error_finalize(error);
                
                // Convert to runtime error and add to aggregator
                let runtime_error = structured_error_to_runtime_error(error);
                if runtime_error {
                    error_aggregator_add_error(aggregator, runtime_error);
                }
                
                structured_error_free(error);
            }
        }
    }
    
    // Finish aggregation
    let result = error_aggregator_finish(aggregator);
    if result && goo_error_union_is_error(result)) {
        fmt.println("   ✅ Error aggregation integration successful");
        let composite = error_aggregator_get_composite_error(aggregator);
        if composite {
            fmt.println("   Aggregated {} errors", composite.get_error_count());
        }
    } else {
        fmt.println("   ❌ Error aggregation integration failed");
    }
    
    if result) {
        goo_error_union_free(result);
    }
}

fn test_real_world_scenarios() {
    fmt.println("   🌍 Testing configuration loading scenario...");
    
    // Simulate configuration loading
    let config_result = try load_config("/nonexistent/config.toml") catch |error| {
        fmt.println("   Expected configuration error occurred:");
        print_structured_error(error);
        return;
    };
    
    fmt.println("   ❌ Expected error but got success");
}

