/// Test file for error aggregation system
/// Demonstrates ErrorAggregator functionality for batch validation

package main

import (
    "fmt"
    "validation"
    "config"
    "http"
)

// =============================================================================
// Test Data Structures
// =============================================================================

struct User {
    id: i32,
    username: string,
    email: string,
    age: i32,
    bio: ?string
}

struct DatabaseConfig {
    host: string,
    port: i32,
    database: string,
    username: string,
    password: string,
    connection_timeout: i32,
    max_connections: i32
}

struct ServerConfig {
    listen_address: string,
    port: i32,
    tls_enabled: bool,
    cert_file: ?string,
    key_file: ?string,
    request_timeout: i32
}

struct ApplicationConfig {
    app_name: string,
    version: string,
    debug: bool,
    log_level: string,
    database: DatabaseConfig,
    server: ServerConfig
}

// =============================================================================
// Validation Functions
// =============================================================================

/// Validate a single user record
fn validate_user(user: User) !void {
    let errors := ErrorAggregator.new(AGGREGATOR_CONTINUE);
    
    // Validate required fields
    errors.try(validate_required_field("username", user.username));
    errors.try(validate_required_field("email", user.email));
    
    // Validate username constraints
    errors.try(validate_string_length("username", user.username, 3, 30));
    
    // Validate email format
    errors.try(validate_email_format("email", user.email));
    
    // Validate age range
    errors.try(validate_numeric_range("age", user.age as f64, 13.0, 120.0));
    
    // Optional bio validation
    if user.bio != null {
        errors.try(validate_string_length("bio", user.bio!, 0, 500));
    }
    
    return errors.finish();
}

/// Validate database configuration
fn validate_database_config(config: DatabaseConfig) !void {
    let errors := ErrorAggregator.new(AGGREGATOR_CONTINUE);
    
    // Validate required connection parameters
    errors.try(validate_required_field("host", config.host));
    errors.try(validate_required_field("database", config.database));
    errors.try(validate_required_field("username", config.username));
    errors.try(validate_required_field("password", config.password));
    
    // Validate string lengths
    errors.try(validate_string_length("host", config.host, 1, 255));
    errors.try(validate_string_length("database", config.database, 1, 64));
    errors.try(validate_string_length("username", config.username, 1, 64));
    errors.try(validate_string_length("password", config.password, 8, 128));
    
    // Validate numeric ranges
    errors.try(validate_numeric_range("port", config.port as f64, 1.0, 65535.0));
    errors.try(validate_numeric_range("connection_timeout", config.connection_timeout as f64, 1.0, 300.0));
    errors.try(validate_numeric_range("max_connections", config.max_connections as f64, 1.0, 1000.0));
    
    return errors.finish();
}

/// Validate server configuration
fn validate_server_config(config: ServerConfig) !void {
    let errors := ErrorAggregator.new(AGGREGATOR_CONTINUE);
    
    // Validate basic server parameters
    errors.try(validate_required_field("listen_address", config.listen_address));
    errors.try(validate_string_length("listen_address", config.listen_address, 1, 255));
    errors.try(validate_numeric_range("port", config.port as f64, 1.0, 65535.0));
    errors.try(validate_numeric_range("request_timeout", config.request_timeout as f64, 1.0, 300.0));
    
    // Validate TLS configuration
    if config.tls_enabled {
        errors.try(validate_required_field("cert_file", config.cert_file));
        errors.try(validate_required_field("key_file", config.key_file));
        
        if config.cert_file != null {
            errors.try(validate_string_length("cert_file", config.cert_file!, 1, 500));
        }
        
        if config.key_file != null {
            errors.try(validate_string_length("key_file", config.key_file!, 1, 500));
        }
    }
    
    return errors.finish();
}

/// Comprehensive application configuration validation
fn validate_config(config: ApplicationConfig) !ValidationResult {
    let errors := ErrorAggregator.new(AGGREGATOR_CONTINUE);
    
    // Set operation name for better error context
    errors.set_operation_name("Application Configuration Validation");
    
    // Validate application metadata
    errors.try(validate_required_field("app_name", config.app_name));
    errors.try(validate_required_field("version", config.version));
    errors.try(validate_required_field("log_level", config.log_level));
    
    errors.try(validate_string_length("app_name", config.app_name, 1, 100));
    errors.try(validate_string_length("version", config.version, 1, 20));
    
    // Validate log level is one of the expected values
    let valid_log_levels = ["debug", "info", "warn", "error"];
    let log_level_valid = false;
    for level in valid_log_levels {
        if config.log_level == level {
            log_level_valid = true;
            break;
        }
    }
    
    if !log_level_valid {
        errors.add_error_with_context(
            ValidationError("Invalid log level", config.log_level),
            "log_level"
        );
    }
    
    // Validate nested configurations
    errors.try(validate_database_config(config.database));
    errors.try(validate_server_config(config.server));
    
    return errors.finish();
}

// =============================================================================
// Batch Validation Examples
// =============================================================================

/// Validate multiple users in batch
fn validate_user_batch(users: []User) !BatchValidationResult {
    let errors := ErrorAggregator.new_with_config(AGGREGATOR_CONTINUE, 50, true);
    
    errors.set_operation_name("User Batch Validation");
    errors.set_collect_warnings(true);
    
    let successful_validations = 0;
    
    for i, user in users {
        let validation_name = fmt.sprintf("user[%d]", i);
        
        let result = try validate_user(user) catch |err| {
            errors.add_error_with_context(err, validation_name);
            continue;
        };
        
        successful_validations++;
    }
    
    let final_result = errors.finish();
    
    return BatchValidationResult{
        total_items: users.length,
        successful_items: successful_validations,
        failed_items: users.length - successful_validations,
        validation_result: final_result
    };
}

/// Parallel validation of configuration files
fn validate_config_files_parallel(config_files: []string) !BatchValidationResult {
    let parallel_collector := ParallelErrorAggregator.new(4); // 4 threads
    defer parallel_collector.free();
    
    // Set up work items (file paths)
    parallel_collector.set_work_items(config_files.data, config_files.length);
    
    // Define the parallel operation
    fn validate_config_file_worker(file_path: *void, thread_id: i32, context: *void) !ApplicationConfig {
        let path = file_path as *string;
        
        // Load and parse config file
        let content = try fs.read_file(path) catch |err| {
            return ConfigError.FileReadError(path, err.message);
        };
        
        let config = try config.parse_toml(content) catch |err| {
            return ConfigError.ParseError(path, err.message);
        };
        
        // Validate the parsed config
        try validate_config(config) catch |err| {
            return ConfigError.ValidationError(path, err.message);
        };
        
        return config;
    }
    
    // Execute parallel validation
    let result = parallel_collector.execute(validate_config_file_worker, null);
    
    return BatchValidationResult{
        total_items: config_files.length,
        successful_items: parallel_collector.get_successful_count(),
        failed_items: parallel_collector.get_failed_count(),
        validation_result: result
    };
}

// =============================================================================
// Error Recovery Integration Tests
// =============================================================================

/// Validate with retry on transient failures
fn validate_with_retry(data: ValidationData) !void {
    let errors := ErrorAggregator.new(AGGREGATOR_CONTINUE);
    
    // Configure retry for transient network errors
    let retry_config := @retry(
        max_attempts=3,
        backoff="exponential",
        initial_delay_ms=100,
        retryable_errors=[5001, 5002, 5003] // Network timeout, connection refused, etc.
    );
    
    errors.set_retry(retry_config);
    
    // Validate external dependencies with retry
    errors.try_with_name(
        validate_external_service_connectivity(data.service_url),
        "external_service_connectivity"
    );
    
    errors.try_with_name(
        validate_database_connectivity(data.db_config),
        "database_connectivity"
    );
    
    errors.try_with_name(
        validate_api_key_validity(data.api_key),
        "api_key_validity"
    );
    
    return errors.finish();
}

/// Validate with circuit breaker protection
fn validate_with_circuit_breaker(batch_data: []ValidationItem) !BatchValidationResult {
    let errors := ErrorAggregator.new(AGGREGATOR_CONTINUE);
    
    // Configure circuit breaker for external validations
    let circuit_breaker := @circuit_breaker(
        failure_threshold=5,
        open_timeout_ms=30000,
        failure_rate_threshold=0.5
    );
    
    errors.set_circuit_breaker(circuit_breaker);
    
    let operations: []CollectableOperation = [];
    let args: []ValidationItem = [];
    
    // Set up batch operations
    for item in batch_data {
        operations.append(validate_external_item);
        args.append(item);
    }
    
    // Execute batch with circuit breaker protection
    let successful_count = errors.execute_batch_with_recovery(
        operations.data,
        args.data,
        batch_data.length,
        null, // No retry
        circuit_breaker
    );
    
    let result = errors.finish();
    
    return BatchValidationResult{
        total_items: batch_data.length,
        successful_items: successful_count,
        failed_items: batch_data.length - successful_count,
        validation_result: result
    };
}

// =============================================================================
// Advanced Error Collection Patterns
// =============================================================================

/// Hierarchical validation with nested error collectors
fn validate_hierarchical_config(config: HierarchicalConfig) !ValidationResult {
    let root_errors := ErrorAggregator.new(AGGREGATOR_CONTINUE);
    root_errors.set_operation_name("Hierarchical Configuration Validation");
    
    // Validate top-level configuration
    root_errors.try(validate_basic_config_structure(config));
    
    // Validate each module with its own collector
    for module_name, module_config in config.modules {
        let module_errors := ErrorAggregator.new(AGGREGATOR_CONTINUE);
        module_errors.set_operation_name(fmt.sprintf("Module '%s' Validation", module_name));
        
        // Validate module-specific configuration
        module_errors.try(validate_module_config(module_config));
        
        // Validate module dependencies
        for dependency in module_config.dependencies {
            module_errors.try_with_name(
                validate_module_dependency(dependency),
                fmt.sprintf("dependency:%s", dependency.name)
            );
        }
        
        // Merge module errors into root collector
        let module_result = module_errors.finish();
        if module_result.is_error() {
            let composite_error = module_errors.get_composite_error();
            root_errors.get_composite_error().merge(composite_error);
        }
    }
    
    return root_errors.finish();
}

/// Custom validation with hooks and monitoring
fn validate_with_monitoring(data: []DataItem) !ValidationResult {
    let errors := ErrorAggregator.new(AGGREGATOR_CONTINUE);
    
    // Set up monitoring hooks
    errors.set_error_hook(on_validation_error, null);
    errors.set_limit_hook(on_error_limit_reached, null);
    errors.set_completion_hook(on_validation_completed, null);
    
    // Configure collection behavior
    errors.set_max_errors(20); // Stop after 20 errors
    errors.set_collect_warnings(true);
    errors.set_collect_context(true);
    
    let validation_start_time = time.now();
    
    // Perform batch validation
    for i, item in data {
        if errors.is_stopped() {
            break;
        }
        
        let item_name = fmt.sprintf("item[%d]", i);
        
        // Validate with detailed context
        errors.try_with_name(
            validate_data_item_comprehensive(item),
            item_name
        );
        
        // Add progress reporting
        if i % 100 == 0 {
            let progress = (i as f64 / data.length as f64) * 100.0;
            fmt.println("Validation progress: {:.1f}%", progress);
        }
    }
    
    let validation_end_time = time.now();
    let duration = validation_end_time.duration_since(validation_start_time);
    
    fmt.println("Validation completed in {} ms", duration.milliseconds());
    fmt.println("Success rate: {:.2f}%", errors.get_success_rate() * 100.0);
    
    return errors.finish();
}

// =============================================================================
// Hook Functions
// =============================================================================

fn on_validation_error(collector: *ErrorAggregator, error: *Error, context: *void) {
    fmt.println("🔴 Validation error collected: {}", error.message);
    
    // Log error details to monitoring system
    monitoring.log_validation_error(
        collector.get_operation_name(),
        error.code,
        error.message
    );
}

fn on_error_limit_reached(collector: *ErrorAggregator, limit: i32, context: *void) {
    fmt.println("⚠️  Error limit reached: {} errors", limit);
    
    // Send alert to monitoring system
    monitoring.send_alert(
        "validation_error_limit_reached",
        fmt.sprintf("Validation stopped after %d errors", limit)
    );
}

fn on_validation_completed(collector: *ErrorAggregator, success: bool, context: *void) {
    let stats = collector.get_composite_error();
    
    if success {
        fmt.println("✅ Validation completed successfully");
        fmt.println("   Total operations: {}", collector.get_success_count());
    } else {
        fmt.println("❌ Validation completed with errors");
        fmt.println("   Total errors: {}", stats.get_error_count());
        fmt.println("   Fatal errors: {}", stats.error_counts.fatal_errors);
        fmt.println("   Validation errors: {}", stats.error_counts.validation_errors);
        fmt.println("   Network errors: {}", stats.error_counts.network_errors);
    }
    
    // Report final statistics
    monitoring.report_validation_completion(
        collector.get_operation_name(),
        success,
        collector.get_success_rate(),
        collector.get_error_count()
    );
}

