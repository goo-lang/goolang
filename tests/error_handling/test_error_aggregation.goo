fn main() -> void {
    fmt.println("🔄 Testing Error Aggregation System");
    fmt.println("===================================");
    
    // Initialize error aggregation system
    error_aggregation_system_init();
    
    // Test 1: Basic error collection
    fmt.println("\n📝 Test 1: Basic Error Collection");
    test_basic_error_collection();
    
    // Test 2: Batch validation
    fmt.println("\n👥 Test 2: Batch User Validation");
    test_batch_user_validation();
    
    // Test 3: Configuration validation
    fmt.println("\n⚙️  Test 3: Configuration Validation");
    test_configuration_validation();
    
    // Test 4: Parallel validation
    fmt.println("\n⚡ Test 4: Parallel Validation");
    test_parallel_validation();
    
    // Test 5: Error recovery integration
    fmt.println("\n🔄 Test 5: Error Recovery Integration");
    test_error_recovery_integration();
    
    // Test 6: Advanced patterns
    fmt.println("\n🚀 Test 6: Advanced Error Collection Patterns");
    test_advanced_patterns();
    
    // Print final statistics
    fmt.println("\n📊 Final Statistics");
    print_error_aggregation_stats();
    
    // Cleanup
    error_aggregation_system_shutdown();
    
    fmt.println("\n✅ All error aggregation tests completed!");
    fmt.println("🎉 Task 20.3 - Error Aggregation System - COMPLETED!");
}

// =============================================================================
// Test Helper Functions
// =============================================================================

fn test_basic_error_collection() {
    let errors := ErrorAggregator.new(AGGREGATOR_CONTINUE);
    errors.set_operation_name("Basic Error Collection Test");
    
    // Simulate some operations with errors
    errors.try(simulate_operation_with_error("network_timeout", 5001));
    errors.try(simulate_operation_with_error("validation_failed", 3001));
    errors.try(simulate_successful_operation("data_processed"));
    errors.try(simulate_operation_with_error("permission_denied", 4001));
    
    let result = errors.finish();
    
    if result.is_error() {
        let composite = errors.get_composite_error();
        fmt.println("   Collected {} errors:", composite.get_error_count());
        
        let summary = composite.to_string();
        fmt.println("{}", summary);
        summary.free();
    } else {
        fmt.println("   All operations succeeded");
    }
    
    fmt.println("   Success rate: {:.1f}%", errors.get_success_rate() * 100.0);
}

fn test_batch_user_validation() {
    // Create test users with various validation issues
    let test_users = [
        User{ id: 1, username: "alice", email: "alice@example.com", age: 25, bio: "Software developer" },
        User{ id: 2, username: "b", email: "invalid-email", age: 15, bio: null }, // Multiple issues
        User{ id: 3, username: "charlie", email: "charlie@test.com", age: 30, bio: "Product manager" },
        User{ id: 4, username: "", email: "dave@example.com", age: 200, bio: "Very long bio that exceeds the maximum allowed length for user bios in our system..." }, // Multiple issues
        User{ id: 5, username: "eve", email: "eve@company.org", age: 28, bio: "UX designer" }
    ];
    
    let result = try validate_user_batch(test_users) catch |err| {
        fmt.println("   Batch validation failed: {}", err.message);
        return;
    };
    
    fmt.println("   Batch validation results:");
    fmt.println("     Total users: {}", result.total_items);
    fmt.println("     Valid users: {}", result.successful_items);
    fmt.println("     Invalid users: {}", result.failed_items);
    
    if result.validation_result.is_error() {
        let composite = result.validation_result.get_error();
        let detailed = composite.to_detailed_string();
        fmt.println("   Validation errors:\n{}", detailed);
        detailed.free();
    }
}

fn test_configuration_validation() {
    // Create test configuration with various issues
    let test_config = ApplicationConfig{
        app_name: "TestApp",
        version: "1.0.0",
        debug: true,
        log_level: "invalid_level", // Issue
        database: DatabaseConfig{
            host: "localhost",
            port: 5432,
            database: "testdb",
            username: "user",
            password: "short", // Issue: too short
            connection_timeout: 30,
            max_connections: 10
        },
        server: ServerConfig{
            listen_address: "0.0.0.0",
            port: 8080,
            tls_enabled: true,
            cert_file: null, // Issue: required for TLS
            key_file: null,  // Issue: required for TLS
            request_timeout: 30
        }
    };
    
    let result = try validate_config(test_config) catch |err| {
        fmt.println("   Configuration validation failed: {}", err.message);
        return;
    };
    
    if result.is_error() {
        let composite = result.get_error();
        fmt.println("   Configuration validation found {} errors:", composite.get_error_count());
        
        let summary = composite.to_string();
        fmt.println("{}", summary);
        summary.free();
    } else {
        fmt.println("   Configuration is valid");
    }
}

fn test_parallel_validation() {
    let config_files = [
        "config/app.toml",
        "config/database.toml", 
        "config/server.toml",
        "config/logging.toml",
        "config/monitoring.toml"
    ];
    
    let result = try validate_config_files_parallel(config_files) catch |err| {
        fmt.println("   Parallel validation failed: {}", err.message);
        return;
    };
    
    fmt.println("   Parallel validation results:");
    fmt.println("     Total files: {}", result.total_items);
    fmt.println("     Valid files: {}", result.successful_items);
    fmt.println("     Invalid files: {}", result.failed_items);
}

fn test_error_recovery_integration() {
    fmt.println("   Testing error collection with retry and circuit breaker...");
    
    // Create test data that will trigger various error conditions
    let validation_data = ValidationData{
        service_url: "https://api.example.com/validate",
        db_config: DatabaseConfig{ /* ... */ },
        api_key: "test_api_key_that_may_be_invalid"
    };
    
    let result = try validate_with_retry(validation_data) catch |err| {
        fmt.println("   Validation with retry failed: {}", err.message);
        return;
    };
    
    if result.is_error() {
        fmt.println("   Some validations failed even with retry");
    } else {
        fmt.println("   All validations succeeded with retry");
    }
}

fn test_advanced_patterns() {
    fmt.println("   Testing advanced error collection patterns...");
    
    // Test hierarchical validation
    let hierarchical_config = HierarchicalConfig{
        /* ... complex nested configuration ... */
    };
    
    let result = try validate_hierarchical_config(hierarchical_config) catch |err| {
        fmt.println("   Hierarchical validation failed: {}", err.message);
        return;
    };
    
    fmt.println("   Hierarchical validation completed");
    
    // Test validation with monitoring
    let test_data = generate_test_data(1000); // Generate 1000 test items
    
    let monitored_result = try validate_with_monitoring(test_data) catch |err| {
        fmt.println("   Monitored validation failed: {}", err.message);
        return;
    };
    
    fmt.println("   Monitored validation completed");
}

// =============================================================================
// Mock Helper Functions
// =============================================================================

fn simulate_operation_with_error(operation_name: string, error_code: i32) !string {
    return Error{ code: error_code, message: fmt.sprintf("{} failed", operation_name) };
}

fn simulate_successful_operation(operation_name: string) !string {
    return fmt.sprintf("{} succeeded", operation_name);
}

fn generate_test_data(count: i32) []DataItem {
    let data: []DataItem = [];
    
    for i in 0..count {
        data.append(DataItem{
            id: i,
            name: fmt.sprintf("item_{}", i),
            value: random_int(0, 1000),
            is_valid: i % 7 != 0 // Make some items invalid
        });
    }
    
    return data;
}

// =============================================================================
// Supporting Types
// =============================================================================

struct ValidationResult {
    success: bool,
    error_count: i32,
    composite_error: ?CompositeError
}

struct BatchValidationResult {
    total_items: i32,
    successful_items: i32,
    failed_items: i32,
    validation_result: ValidationResult
}

struct ValidationData {
    service_url: string,
    db_config: DatabaseConfig,
    api_key: string
}

struct ValidationItem {
    id: i32,
    data: string,
    validation_type: string
}

struct DataItem {
    id: i32,
    name: string,
    value: i32,
    is_valid: bool
}

struct HierarchicalConfig {
    modules: map[string]ModuleConfig
}

struct ModuleConfig {
    name: string,
    enabled: bool,
    dependencies: []ModuleDependency
}

struct ModuleDependency {
    name: string,
    version: string,
    required: bool
}