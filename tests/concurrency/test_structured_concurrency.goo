// Comprehensive test suite for Structured Concurrency Framework
// Tests the fearless concurrency system's structured concurrency implementation

package main

import (
    "testing"
    "time"
    "sync"
)

// Test basic concurrency scope creation and management
func test_scope_management() {
    // Create root scope
    root_scope := concurrency_scope_create("root", nil)
    defer concurrency_scope_destroy(root_scope)
    
    assert(root_scope != nil, "Root scope creation should succeed")
    assert(root_scope.name == "root", "Root scope should have correct name")
    assert(root_scope.parent == nil, "Root scope should have no parent")
    
    // Create child scope
    child_scope := concurrency_scope_create("child", root_scope)
    defer concurrency_scope_destroy(child_scope)
    
    assert(child_scope != nil, "Child scope creation should succeed")
    assert(child_scope.parent == root_scope, "Child should have correct parent")
    
    println("✓ Scope management test passed")
}

// Test basic task creation and execution
func test_task_execution() {
    scope := concurrency_scope_create("test_scope", nil)
    defer concurrency_scope_destroy(scope)
    
    // Simple task function
    executed := false
    task_func := func(context *void, token *CancellationToken) *void {
        executed = true
        return &int{42}
    }
    
    // Create and start task
    task := concurrent_task_create("simple_task", task_func, nil)
    defer concurrent_task_destroy(task)
    
    success := concurrent_task_start(task)
    assert(success, "Task start should succeed")
    
    // Wait for completion
    result := concurrent_task_await(task)
    assert(result != nil, "Task result should not be null")
    assert(*(int*)result == 42, "Task result should be 42")
    assert(executed, "Task function should have been executed")
    
    // Check final state
    state := concurrent_task_get_state(task)
    assert(state == TASK_STATE_COMPLETED, "Task should be completed")
    assert(concurrent_task_is_completed(task), "Task should report as completed")
    
    println("✓ Task execution test passed")
}

// Test task cancellation
func test_task_cancellation() {
    scope := concurrency_scope_create("cancel_scope", nil)
    defer concurrency_scope_destroy(scope)
    
    // Long-running task that checks for cancellation
    cancelled := false
    task_func := func(context *void, token *CancellationToken) *void {
        for i := 0; i < 1000; i++ {
            if cancellation_token_is_cancelled(token) {
                cancelled = true
                return nil
            }
            usleep(1000) // 1ms
        }
        return &int{99} // Should not reach here
    }
    
    task := concurrent_task_create("cancellable_task", task_func, nil)
    defer concurrent_task_destroy(task)
    
    // Start task and cancel it quickly
    concurrent_task_start(task)
    usleep(5000) // Let it run for 5ms
    concurrent_task_cancel(task, CANCEL_REASON_USER)
    
    // Wait for completion
    result := concurrent_task_await_timeout(task, 1000) // 1 second timeout
    assert(result == nil, "Cancelled task should return null")
    assert(cancelled, "Task should have detected cancellation")
    assert(concurrent_task_is_cancelled(task), "Task should report as cancelled")
    
    println("✓ Task cancellation test passed")
}

// Test cancellation token hierarchy
func test_cancellation_hierarchy() {
    // Create parent token
    parent_token := cancellation_token_create(nil)
    defer cancellation_token_destroy(parent_token)
    
    // Create child token
    child_token := cancellation_token_create(parent_token)
    defer cancellation_token_destroy(child_token)
    
    assert(!cancellation_token_is_cancelled(parent_token), "Parent should not be cancelled initially")
    assert(!cancellation_token_is_cancelled(child_token), "Child should not be cancelled initially")
    
    // Cancel parent - should cascade to child
    cancellation_token_cancel(parent_token, CANCEL_REASON_USER)
    
    // Give time for propagation
    usleep(1000)
    
    assert(cancellation_token_is_cancelled(parent_token), "Parent should be cancelled")
    assert(cancellation_token_is_cancelled(child_token), "Child should be cancelled by parent")
    
    println("✓ Cancellation hierarchy test passed")
}

// Test task groups with success scenario
func test_task_group_success() {
    scope := concurrency_scope_create("group_scope", nil)
    defer concurrency_scope_destroy(scope)
    
    group := task_group_create("test_group", scope)
    defer task_group_destroy(group)
    
    // Create multiple tasks that succeed
    const NUM_TASKS = 3
    task_results := [NUM_TASKS]int{10, 20, 30}
    
    for i := 0; i < NUM_TASKS; i++ {
        expected_result := task_results[i]
        task_func := func(context *void, token *CancellationToken) *void {
            // Simulate some work
            usleep(random_int(1000, 5000)) // 1-5ms
            return &expected_result
        }
        
        task := concurrent_task_create("group_task_" + string(i), task_func, nil)
        task_group_add_task(group, task)
        concurrent_task_start(task)
    }
    
    // Wait for all tasks to complete
    success := task_group_wait_for_completion(group, 10000) // 10 second timeout
    assert(success, "Task group should complete successfully")
    
    // Get results
    result_count := 0
    results := task_group_get_results(group, &result_count)
    assert(result_count == NUM_TASKS, "Should have correct number of results")
    
    // Verify results
    for i := 0; i < NUM_TASKS; i++ {
        assert(results[i] != nil, "Task result should not be null")
        assert(*(int*)results[i] == task_results[i], "Task result should match expected")
    }
    
    println("✓ Task group success test passed")
}

// Test task groups with fail-fast behavior
func test_task_group_fail_fast() {
    scope := concurrency_scope_create("fail_scope", nil)
    defer concurrency_scope_destroy(scope)
    
    group := task_group_create("fail_group", scope)
    group.fail_fast = true
    defer task_group_destroy(group)
    
    // Create tasks where one will fail
    const NUM_TASKS = 5
    
    for i := 0; i < NUM_TASKS; i++ {
        task_index := i
        task_func := func(context *void, token *CancellationToken) *void {
            if task_index == 2 {
                // This task will fail
                usleep(2000) // 2ms delay
                return nil // Simulate failure
            } else {
                // Other tasks run longer
                for j := 0; j < 100; j++ {
                    if cancellation_token_is_cancelled(token) {
                        return nil // Cancelled due to fail-fast
                    }
                    usleep(1000) // 1ms each iteration
                }
                return &task_index
            }
        }
        
        task := concurrent_task_create("fail_task_" + string(i), task_func, nil)
        task_group_add_task(group, task)
        concurrent_task_start(task)
    }
    
    // Wait for completion (should be quick due to fail-fast)
    start_time := get_current_time_ms()
    success := task_group_wait_for_completion(group, 5000) // 5 second timeout
    elapsed := get_current_time_ms() - start_time
    
    assert(success, "Task group should complete (even with failures)")
    assert(elapsed < 1000, "Fail-fast should complete quickly") // Less than 1 second
    
    println("✓ Task group fail-fast test passed")
}

// Test concurrent task dependencies
func test_task_dependencies() {
    scope := concurrency_scope_create("dep_scope", nil)
    defer concurrency_scope_destroy(scope)
    
    // Create tasks with dependencies: task3 depends on task1 and task2
    execution_order := []string{}
    order_mutex := sync.Mutex{}
    
    add_to_order := func(name string) {
        order_mutex.Lock()
        execution_order = append(execution_order, name)
        order_mutex.Unlock()
    }
    
    task1_func := func(context *void, token *CancellationToken) *void {
        usleep(10000) // 10ms
        add_to_order("task1")
        return &int{1}
    }
    
    task2_func := func(context *void, token *CancellationToken) *void {
        usleep(15000) // 15ms
        add_to_order("task2")
        return &int{2}
    }
    
    task3_func := func(context *void, token *CancellationToken) *void {
        usleep(5000) // 5ms (shorter, but should wait for dependencies)
        add_to_order("task3")
        return &int{3}
    }
    
    task1 := concurrent_task_create("task1", task1_func, nil)
    task2 := concurrent_task_create("task2", task2_func, nil)
    task3 := concurrent_task_create("task3", task3_func, nil)
    
    defer concurrent_task_destroy(task1)
    defer concurrent_task_destroy(task2)
    defer concurrent_task_destroy(task3)
    
    // Create dependencies
    dep1 := task_dependency_create(task1, task3, DEPENDENCY_SEQUENTIAL)
    dep2 := task_dependency_create(task2, task3, DEPENDENCY_SEQUENTIAL)
    defer task_dependency_destroy(dep1)
    defer task_dependency_destroy(dep2)
    
    // Start all tasks
    concurrent_task_start(task1)
    concurrent_task_start(task2)
    concurrent_task_start(task3) // Should wait for task1 and task2
    
    // Wait for all to complete
    concurrent_task_await(task1)
    concurrent_task_await(task2)
    concurrent_task_await(task3)
    
    // Verify execution order
    assert(len(execution_order) == 3, "Should have 3 execution records")
    
    // task3 should execute after both task1 and task2
    task3_index := -1
    task1_index := -1
    task2_index := -1
    
    for i, name := range execution_order {
        if name == "task1" {
            task1_index = i
        } else if name == "task2" {
            task2_index = i
        } else if name == "task3" {
            task3_index = i
        }
    }
    
    assert(task1_index < task3_index, "task1 should complete before task3")
    assert(task2_index < task3_index, "task2 should complete before task3")
    
    println("✓ Task dependencies test passed")
}

// Test structured parallel execution
func test_parallel_execution() {
    scope := concurrency_scope_create("parallel_scope", nil)
    defer concurrency_scope_destroy(scope)
    
    // Test parallel execution of multiple functions
    const NUM_FUNCTIONS = 4
    function_results := [NUM_FUNCTIONS]int{100, 200, 300, 400}
    
    functions := make([]TaskFunction, NUM_FUNCTIONS)
    contexts := make([]*void, NUM_FUNCTIONS)
    
    for i := 0; i < NUM_FUNCTIONS; i++ {
        expected := function_results[i]
        functions[i] = func(context *void, token *CancellationToken) *void {
            // Simulate work
            usleep(random_int(5000, 15000)) // 5-15ms
            return &expected
        }
        contexts[i] = nil
    }
    
    // Execute all functions in parallel
    start_time := get_current_time_ms()
    results := parallel_execute(scope, functions, contexts, NUM_FUNCTIONS, 30000) // 30s timeout
    elapsed := get_current_time_ms() - start_time
    
    assert(results != nil, "Parallel execution should return results")
    
    // Verify results
    for i := 0; i < NUM_FUNCTIONS; i++ {
        assert(results[i] != nil, "Result should not be null")
        assert(*(int*)results[i] == function_results[i], "Result should match expected")
    }
    
    // Should complete faster than sequential execution
    assert(elapsed < NUM_FUNCTIONS * 15, "Parallel execution should be faster than sequential")
    
    println("✓ Parallel execution test passed")
}

// Test scope-wide cancellation
func test_scope_cancellation() {
    scope := concurrency_scope_create("cancel_scope", nil)
    defer concurrency_scope_destroy(scope)
    
    // Create multiple long-running tasks
    const NUM_TASKS = 5
    cancelled_count := 0
    count_mutex := sync.Mutex{}
    
    for i := 0; i < NUM_TASKS; i++ {
        task_func := func(context *void, token *CancellationToken) *void {
            for j := 0; j < 100; j++ {
                if cancellation_token_is_cancelled(token) {
                    count_mutex.Lock()
                    cancelled_count++
                    count_mutex.Unlock()
                    return nil
                }
                usleep(10000) // 10ms per iteration
            }
            return &int{999} // Should not reach here
        }
        
        task := concurrent_task_create("scope_task_" + string(i), task_func, nil)
        concurrent_task_start(task)
    }
    
    // Let tasks run for a bit
    usleep(50000) // 50ms
    
    // Cancel entire scope
    concurrency_scope_cancel_all(scope, CANCEL_REASON_USER)
    
    // Wait for scope to empty
    success := concurrency_scope_wait_for_completion(scope, 5000) // 5s timeout
    assert(success, "Scope should complete after cancellation")
    
    count_mutex.Lock()
    final_cancelled_count := cancelled_count
    count_mutex.Unlock()
    
    assert(final_cancelled_count == NUM_TASKS, "All tasks should have been cancelled")
    
    println("✓ Scope cancellation test passed")
}

// Test error handling and recovery
func test_error_handling() {
    scope := concurrency_scope_create("error_scope", nil)
    defer concurrency_scope_destroy(scope)
    
    // Create tasks where some will fail
    const NUM_TASKS = 6
    const NUM_FAILING = 2
    
    tasks := make([]*ConcurrentTask, NUM_TASKS)
    
    for i := 0; i < NUM_TASKS; i++ {
        task_index := i
        task_func := func(context *void, token *CancellationToken) *void {
            usleep(random_int(5000, 15000)) // 5-15ms
            
            if task_index < NUM_FAILING {
                // These tasks will fail
                // In a real implementation, we'd set an error on the task
                return nil
            } else {
                // These tasks succeed
                return &task_index
            }
        }
        
        tasks[i] = concurrent_task_create("error_task_" + string(i), task_func, nil)
        concurrent_task_start(tasks[i])
    }
    
    // Wait for all tasks to complete
    for i := 0; i < NUM_TASKS; i++ {
        concurrent_task_await(tasks[i])
    }
    
    // Check results and errors
    success_count := 0
    failure_count := 0
    
    for i := 0; i < NUM_TASKS; i++ {
        state := concurrent_task_get_state(tasks[i])
        if state == TASK_STATE_COMPLETED {
            success_count++
        } else if state == TASK_STATE_FAILED {
            failure_count++
        }
        
        concurrent_task_destroy(tasks[i])
    }
    
    assert(success_count == NUM_TASKS - NUM_FAILING, "Expected number of successful tasks")
    // Note: failure_count might be 0 if tasks return null without setting error state
    
    println("✓ Error handling test passed")
}

// Test performance and resource usage
func test_performance_monitoring() {
    scope := concurrency_scope_create("perf_scope", nil)
    defer concurrency_scope_destroy(scope)
    
    // Create tasks with different workloads
    const NUM_TASKS = 10
    
    for i := 0; i < NUM_TASKS; i++ {
        workload := i * 1000 + 5000 // 5ms to 14ms
        
        task_func := func(context *void, token *CancellationToken) *void {
            start := get_current_time_ms()
            
            // Simulate CPU work
            while get_current_time_ms() - start < workload {
                if cancellation_token_is_cancelled(token) {
                    return nil
                }
                // Busy work
                volatile_sum := 0
                for j := 0; j < 1000; j++ {
                    volatile_sum += j
                }
            }
            
            return &workload
        }
        
        task := concurrent_task_create("perf_task_" + string(i), task_func, nil)
        concurrent_task_start(task)
    }
    
    // Monitor performance
    start_time := get_current_time_ms()
    success := concurrency_scope_wait_for_completion(scope, 30000) // 30s timeout
    total_time := get_current_time_ms() - start_time
    
    assert(success, "Performance test should complete")
    
    printf("Performance test completed in %lu ms\n", total_time)
    printf("Average time per task: %.2f ms\n", (double)total_time / NUM_TASKS)
    
    // Get scheduler metrics if available
    scheduler := get_global_concurrency_scheduler()
    if scheduler != nil {
        metrics := get_concurrency_metrics(scheduler)
        print_concurrency_metrics(&metrics)
    }
    
    println("✓ Performance monitoring test passed")
}

// Test timeout handling
func test_timeout_handling() {
    scope := concurrency_scope_create("timeout_scope", nil)
    defer concurrency_scope_destroy(scope)
    
    // Create a task that runs longer than its timeout
    task_func := func(context *void, token *CancellationToken) *void {
        // This should run for ~2 seconds
        for i := 0; i < 200; i++ {
            if cancellation_token_is_cancelled(token) {
                return nil
            }
            usleep(10000) // 10ms per iteration
        }
        return &int{999}
    }
    
    task := concurrent_task_create("timeout_task", task_func, nil)
    task.config.timeout_ms = 100 // 100ms timeout
    defer concurrent_task_destroy(task)
    
    concurrent_task_start(task)
    
    // Wait with shorter timeout
    start_time := get_current_time_ms()
    result := concurrent_task_await_timeout(task, 500) // 500ms wait
    elapsed := get_current_time_ms() - start_time
    
    assert(result == nil, "Timed out task should return null")
    assert(elapsed < 1000, "Timeout should happen quickly") // Less than 1 second
    
    println("✓ Timeout handling test passed")
}

// Test resource limits and memory management
func test_resource_management() {
    scope := concurrency_scope_create("resource_scope", nil)
    defer concurrency_scope_destroy(scope)
    
    // Set resource limits
    scope.memory_limit = 1024 * 1024 // 1MB limit
    scope.thread_limit = 4          // 4 thread limit
    
    // Create tasks that allocate memory
    const NUM_TASKS = 8
    
    for i := 0; i < NUM_TASKS; i++ {
        allocation_size := 128 * 1024 // 128KB per task
        
        task_func := func(context *void, token *CancellationToken) *void {
            // Allocate memory (in real implementation, would track against scope limit)
            buffer := malloc(allocation_size)
            defer free(buffer)
            
            // Do some work with the buffer
            memset(buffer, i % 256, allocation_size)
            
            usleep(random_int(10000, 20000)) // 10-20ms
            
            return &i
        }
        
        task := concurrent_task_create("resource_task_" + string(i), task_func, nil)
        concurrent_task_start(task)
    }
    
    // Wait for completion
    success := concurrency_scope_wait_for_completion(scope, 10000) // 10s timeout
    assert(success, "Resource management test should complete")
    
    // Check that memory usage is tracked (would be implemented in full system)
    printf("Final memory usage: %zu bytes\n", scope.memory_used)
    printf("Active threads: %d\n", scope.active_threads)
    
    println("✓ Resource management test passed")
}

