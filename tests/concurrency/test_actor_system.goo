// =============================================================================

fn main() -> void {
    fmt.println("🎭 Testing Actor System Core - Fearless Concurrency");
    fmt.println("====================================================");
    
    // Initialize actor system
    actor_system_init();
    defer actor_system_shutdown();
    
    // Initialize error handling integration
    error_hierarchy_system_init();
    defer error_hierarchy_system_shutdown();
    
    try {
        // Core functionality tests
        test_basic_actor_operations();
        test_concurrent_actor_access();
        test_actor_error_handling();
        test_actor_futures();
        
        // Advanced features tests
        test_actor_supervision();
        test_actor_lifecycle();
        
        // Performance tests
        test_high_throughput_messaging();
        
    } catch |error| {
        fmt.println("❌ Test failed: {}", error.message);
        print_structured_error(error);
        return;
    }
    
    fmt.println("\n🎉 All Actor System Tests Passed!");
    fmt.println("✅ Task 21.1 - Actor System Core - COMPLETED!");
    
    fmt.println("\n📊 Actor System Features Demonstrated:");
    fmt.println("=====================================");
    fmt.println("✓ Type-safe actor creation and spawning");
    fmt.println("✓ Asynchronous message passing with futures");
    fmt.println("✓ Actor state isolation and management");
    fmt.println("✓ Error handling and propagation");
    fmt.println("✓ Concurrent access and thread safety");
    fmt.println("✓ Actor supervision and lifecycle management");
    fmt.println("✓ High-throughput message processing");
    fmt.println("✓ Graceful shutdown and resource cleanup");
    fmt.println("");
    fmt.println("🚀 Ready for Task 21.2 - Shared Variables with Automatic Synchronization!");
}