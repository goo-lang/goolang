// Performance benchmark
func benchmark_atomic_operations() {
    counter := shared_var_create("benchmark_counter", SHARED_TYPE_INT64, &int64{0})
    defer shared_var_destroy(counter)
    
    const OPERATIONS = 1000000
    
    start_time := get_current_time_ms()
    
    for i := 0; i < OPERATIONS; i++ {
        shared_var_atomic_inc_int(counter, MEMORY_ORDER_RELAXED)
    }
    
    end_time := get_current_time_ms()
    elapsed := end_time - start_time
    
    final_value := int64(0)
    shared_var_read(counter, &final_value, MEMORY_ORDER_SEQ_CST)
    
    ops_per_ms := float64(OPERATIONS) / float64(elapsed)
    
    println("Benchmark Results:")
    println("  Operations: " + string(OPERATIONS))
    println("  Time: " + string(elapsed) + "ms")
    println("  Rate: " + string(ops_per_ms) + " ops/ms")
    println("  Final value: " + string(final_value))
    
    assert(final_value == OPERATIONS, "All operations should be accounted for")
    
    println("✓ Performance benchmark completed")
}

