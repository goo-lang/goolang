func main() {
    println("=== Shared Variables Test Suite ===")
    println("")
    
    test_basic_operations()
    test_atomic_operations()
    test_compare_swap()
    test_bitwise_operations()
    test_memory_orderings()
    test_concurrent_access()
    test_change_notifications()
    test_parallel_loops()
    test_performance_statistics()
    test_system_management()
    test_error_conditions()
    test_actor_integration()
    benchmark_atomic_operations()
    
    println("")
    println("=== All Tests Passed! ===")
    println("Shared Variables system is working correctly.")
    println("✓ Automatic synchronization: Working")
    println("✓ Lock-free operations: Working") 
    println("✓ Memory ordering: Working")
    println("✓ Change notifications: Working")
    println("✓ Parallel processing: Working")
    println("✓ Thread safety: Working")
    println("✓ Performance: Acceptable")
    
    return 0
}

// Helper functions
func assert(condition bool, message string) {
    if !condition {
        println("ASSERTION FAILED: " + message)
        exit(1)
    }
}

func sleep_ms(ms int) {
    // Sleep for specified milliseconds
    usleep(ms * 1000)
}

func get_current_time_ms() uint64 {
    // Get current time in milliseconds
    return uint64(time.Now().UnixNano() / 1000000)
}

func spawn_thread(func_ptr func()) {
    // Spawn a thread to run the given function
    go func_ptr()
}