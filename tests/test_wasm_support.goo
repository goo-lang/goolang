// WebAssembly Support Test
// Demonstrates WebAssembly compilation target features in Goo

package main

// Import JavaScript functions for browser environment
import "js" {
    console_log: func(message: string)
    alert: func(message: string)
    document_get_element_by_id: func(id: string) -> Element
}

// WebAssembly memory declaration
memory 1 16  // Initial: 1 page (64KB), Maximum: 16 pages (1MB)

// WebAssembly table for function references
table 10 funcref

// WebAssembly global variables
global counter i32 0
global pi f64 3.14159265359

// Export functions to JavaScript
export "add" func add(a: i32, b: i32) -> i32 {
    return a + b
}

export "factorial" func factorial(n: i32) -> i32 {
    if n <= 1 {
        return 1
    }
    return n * factorial(n - 1)
}

export "fibonacci" func fibonacci(n: i32) -> i32 {
    if n <= 1 {
        return n
    }
    return fibonacci(n - 1) + fibonacci(n - 2)
}

// WebAssembly linear memory operations
func memoryTest() {
    // Allocate and manipulate memory
    ptr := wasm_malloc(1024)
    
    // Write to memory
    wasm_store_i32(ptr, 42)
    wasm_store_i32(ptr + 4, 84)
    
    // Read from memory
    val1 := wasm_load_i32(ptr)
    val2 := wasm_load_i32(ptr + 4)
    
    println("Memory values:", val1, val2)
    
    wasm_free(ptr)
}

// JavaScript interoperability examples
func jsInteropTest() {
    // Call JavaScript console.log
    console.log("Hello from WebAssembly!")
    
    // Access DOM elements
    element := document.getElementById("myButton")
    if element != nil {
        element.textContent = "Clicked from WASM!"
    }
    
    // Handle JavaScript events
    window.addEventListener("click", func(event: Event) {
        console.log("Click detected in WASM handler")
    })
}

// WebAssembly SIMD operations (if supported)
func simdTest() {
    // Vector operations using WebAssembly SIMD
    v1 := v128_const(1, 2, 3, 4)  // 4x i32 vector
    v2 := v128_const(5, 6, 7, 8)
    
    result := i32x4_add(v1, v2)  // SIMD addition
    
    // Extract individual elements
    for i := 0; i < 4; i++ {
        val := i32x4_extract_lane(result, i)
        println("SIMD result[", i, "] =", val)
    }
}

// Concurrency model for WebAssembly
func concurrencyTest() {
    // WebAssembly doesn't support threads by default
    // But we can use cooperative concurrency
    
    ch := make(chan int, 10)
    
    // Simulate goroutine with event loop integration
    go func() {
        for i := 0; i < 5; i++ {
            ch <- i
            yield()  // Yield control to event loop
        }
        close(ch)
    }()
    
    // Receive values cooperatively
    for val := range ch {
        println("Received:", val)
        yield()  // Allow other tasks to run
    }
}

// Error handling with WebAssembly
func errorHandlingTest() !string {
    // WebAssembly doesn't have native exception handling
    // Use error unions for proper error propagation
    
    result := try riskyOperation()
    return result
}

func riskyOperation() !string {
    if global_counter < 0 {
        return Error.new("Counter cannot be negative")
    }
    return "Success"
}

// WebAssembly bulk memory operations
func bulkMemoryTest() {
    src := []byte{1, 2, 3, 4, 5}
    dst := make([]byte, 5)
    
    // Bulk memory copy (WebAssembly bulk memory operations)
    memory.copy(dst, src, 5)
    
    // Bulk memory fill
    memory.fill(dst[2:], 0xFF, 3)
    
    for i, val := range dst {
        println("dst[", i, "] =", val)
    }
}

// Reference types and function tables
func referenceTypesTest() {
    // Function table operations
    funcs := []func(int) int{
        func(x: int) int { return x * 2 },
        func(x: int) int { return x * x },
        func(x: int) int { return x + 10 },
    }
    
    // Store functions in WebAssembly table
    for i, f := range funcs {
        table.set(i, f)
    }
    
    // Call functions through table
    for i := 0; i < 3; i++ {
        f := table.get(i)
        result := f(5)
        println("Function", i, "result:", result)
    }
}

// WebAssembly modules and imports
func moduleTest() {
    // Import external WebAssembly module
    mathModule := wasm.instantiate("math", map[string]interface{}{
        "env": map[string]interface{}{
            "memory": memory,
            "table":  table,
        },
    })
    
    // Call imported function
    result := mathModule.exports.complex_calculation(10, 20)
    println("Complex calculation result:", result)
}

// Performance testing
func performanceTest() {
    start := performance.now()
    
    // CPU-intensive task
    sum := 0
    for i := 0; i < 1000000; i++ {
        sum += i * i
    }
    
    end := performance.now()
    duration := end - start
    
    console.log("Performance test completed in", duration, "ms")
    console.log("Sum:", sum)
}

// WebAssembly debugging support
func debugTest() {
    // WebAssembly debugging with source maps
    debugger  // Breakpoint for browser debugger
    
    x := 42
    y := x * 2
    
    // Custom debug output
    debug.log("Debug values:", x, y)
    debug.trace()  // Stack trace
}

// Browser API integration
func browserAPITest() {
    // Fetch API integration
    response, err := fetch("https://api.example.com/data")
    if err != nil {
        console.error("Fetch failed:", err)
        return
    }
    
    data := try response.json()
    console.log("API data:", data)
    
    // Canvas API integration
    canvas := document.createElement("canvas")
    ctx := canvas.getContext("2d")
    
    // Draw on canvas from WebAssembly
    ctx.fillStyle = "red"
    ctx.fillRect(10, 10, 100, 100)
    
    document.body.appendChild(canvas)
}

// Node.js environment support
func nodeJSTest() {
    if runtime.environment == "node" {
        // Node.js specific operations
        fs := require("fs")
        
        data := "Hello from Goo WebAssembly!"
        fs.writeFileSync("output.txt", data)
        
        content := fs.readFileSync("output.txt", "utf8")
        console.log("File content:", content)
    }
}

// WASI (WebAssembly System Interface) support
func wasiTest() {
    if runtime.environment == "wasi" {
        // WASI filesystem operations
        file := wasi.fd_open("test.txt", WASI_O_CREAT | WASI_O_WRONLY)
        
        data := "WASI file operations from Goo!"
        wasi.fd_write(file, data)
        wasi.fd_close(file)
        
        // WASI environment variables
        path := wasi.environ_get("PATH")
        println("PATH:", path)
    }
}

// Main function and startup
func main() {
    println("=== Goo WebAssembly Support Test ===")
    
    // Detect runtime environment
    env := detectEnvironment()
    println("Runtime environment:", env)
    
    // Run tests based on environment
    match env {
        case "browser":
            println("\n1. JavaScript Interop Test:")
            jsInteropTest()
            
            println("\n2. Browser API Test:")
            browserAPITest()
            
            println("\n3. DOM Integration Test:")
            domIntegrationTest()
            
        case "node":
            println("\n1. Node.js Integration Test:")
            nodeJSTest()
            
        case "wasi":
            println("\n1. WASI Integration Test:")
            wasiTest()
            
        default:
            println("Unknown environment")
    }
    
    // Common tests for all environments
    println("\n4. Memory Operations Test:")
    memoryTest()
    
    println("\n5. Bulk Memory Test:")
    bulkMemoryTest()
    
    println("\n6. Reference Types Test:")
    referenceTypesTest()
    
    println("\n7. Error Handling Test:")
    result := errorHandlingTest() catch |err| {
        println("Error caught:", err)
        "Error handled"
    }
    println("Error handling result:", result)
    
    println("\n8. Performance Test:")
    performanceTest()
    
    println("\n9. Concurrency Test:")
    concurrencyTest()
    
    if supportsSIMD() {
        println("\n10. SIMD Test:")
        simdTest()
    }
    
    println("\nWebAssembly tests completed!")
}

// Helper functions

func detectEnvironment() string {
    // Detect the WebAssembly runtime environment
    if typeof(window) != "undefined" {
        return "browser"
    } else if typeof(global) != "undefined" && typeof(process) != "undefined" {
        return "node"
    } else if typeof(WASI) != "undefined" {
        return "wasi"
    } else {
        return "unknown"
    }
}

func supportsSIMD() bool {
    // Check if WebAssembly SIMD is supported
    return WebAssembly.validate(new Uint8Array([
        0x00, 0x61, 0x73, 0x6d, 0x01, 0x00, 0x00, 0x00,  // WASM header
        0x01, 0x05, 0x01, 0x60, 0x01, 0x7b, 0x00,        // SIMD type signature
    ]))
}

func domIntegrationTest() {
    // Create interactive DOM elements
    button := document.createElement("button")
    button.textContent = "Click me (WASM)"
    button.onclick = func() {
        alert("Button clicked from WebAssembly!")
        updateCounter()
    }
    
    counter_display := document.createElement("div")
    counter_display.id = "counter"
    counter_display.textContent = "Counter: 0"
    
    document.body.appendChild(button)
    document.body.appendChild(counter_display)
}

func updateCounter() {
    global_counter++
    element := document.getElementById("counter")
    if element != nil {
        element.textContent = "Counter: " + string(global_counter)
    }
}

func yield() {
    // Cooperative yielding for single-threaded WebAssembly
    setTimeout(func() {
        // Resume execution on next tick
    }, 0)
}

// WebAssembly-specific intrinsic functions
func wasm_malloc(size: int) -> uintptr {
    // Allocate memory in WebAssembly linear memory
    return __builtin_wasm_memory_grow(size)
}

func wasm_free(ptr: uintptr) {
    // Free memory (simplified implementation)
    // In real implementation, this would manage a heap
}

func wasm_store_i32(addr: uintptr, value: i32) {
    // Store 32-bit integer to memory
    __builtin_wasm_i32_store(addr, value)
}

func wasm_load_i32(addr: uintptr) -> i32 {
    // Load 32-bit integer from memory
    return __builtin_wasm_i32_load(addr)
}

// WebAssembly SIMD intrinsics (conditional compilation based on support)
func v128_const(a, b, c, d: i32) -> v128 {
    return __builtin_wasm_i32x4_const(a, b, c, d)
}

func i32x4_add(a, b: v128) -> v128 {
    return __builtin_wasm_i32x4_add(a, b)
}

func i32x4_extract_lane(v: v128, lane: int) -> i32 {
    return __builtin_wasm_i32x4_extract_lane(v, lane)
}

// Build configuration for WebAssembly target
// goo build --target=wasm32 --env=browser test_wasm_support.goo
// goo build --target=wasm32 --env=node test_wasm_support.goo
// goo build --target=wasm32 --env=wasi test_wasm_support.goo