func DisableInterrupts() {
    disable_interrupts()
}

func EnableInterrupts() {
    enable_interrupts()
}

func InterruptsEnabled() -> bool {
    return interrupts_enabled()
}

// Timer functions
func GetSystemTime() -> uint64 {
