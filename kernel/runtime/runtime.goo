// Package runtime provides the kernel runtime for bare-metal execution
package runtime

// Kernel runtime configuration
type KernelConfig struct {
    heap_start: uintptr
    heap_size: usize
    stack_size: usize
    max_processes: uint32
    page_size: usize
}

// Memory layout for kernel
type MemoryLayout struct {
    kernel_start: uintptr
    kernel_end: uintptr
    heap_start: uintptr
    heap_end: uintptr
    stack_start: uintptr
    stack_end: uintptr
    mmio_start: uintptr
    mmio_end: uintptr
}

// Platform-specific types
type PhysAddr = uintptr
type VirtAddr = uintptr
type PageFrame = uintptr

// Error types for kernel operations
type KernelError struct {
    message: string
    kind: KernelErrorKind
}

type KernelErrorKind enum {
    OutOfMemory,
    InvalidAddress,
    PermissionDenied,
    ResourceBusy,
    DeviceError,
    InvalidArgument,
    NotSupported
}

var (
    ErrOutOfMemory = KernelError{message: "out of memory", kind: KernelErrorKind.OutOfMemory}
    ErrInvalidAddress = KernelError{message: "invalid address", kind: KernelErrorKind.InvalidAddress}
    ErrPermissionDenied = KernelError{message: "permission denied", kind: KernelErrorKind.PermissionDenied}
    ErrResourceBusy = KernelError{message: "resource busy", kind: KernelErrorKind.ResourceBusy}
    ErrDeviceError = KernelError{message: "device error", kind: KernelErrorKind.DeviceError}
    ErrInvalidArgument = KernelError{message: "invalid argument", kind: KernelErrorKind.InvalidArgument}
    ErrNotSupported = KernelError{message: "operation not supported", kind: KernelErrorKind.NotSupported}
)

func (e: KernelError) Error() -> string {
    return e.message
}

// Kernel runtime state
var kernel_config: KernelConfig
var memory_layout: MemoryLayout
var is_initialized: bool = false

// Initialize the kernel runtime
func KernelInit(config: KernelConfig, layout: MemoryLayout) -> !KernelError {
    if is_initialized {
        return ErrInvalidArgument
    }
    
    kernel_config = config
    memory_layout = layout
    
    // Initialize memory management
    init_heap(layout.heap_start, layout.heap_end)?
    
    // Initialize interrupt handling
    init_interrupts()?
    
    // Initialize platform-specific features
    platform_init()?
    
    is_initialized = true
    return nil
}

// Memory allocation for kernel
func KAlloc(size: usize) -> (?*byte, !KernelError) {
    if !is_initialized {
        return nil, ErrInvalidArgument
    }
    
    ptr := heap_alloc(size)
    if ptr == null {
        return nil, ErrOutOfMemory
    }
    
    return ptr, nil
}

// Free kernel memory
func KFree(ptr: *byte) -> !KernelError {
    if !is_initialized {
        return ErrInvalidArgument
    }
    
    if ptr == null {
        return ErrInvalidArgument
    }
    
    heap_free(ptr)
    return nil
}

// Allocate aligned memory
func KAllocAligned(size: usize, align: usize) -> (?*byte, !KernelError) {
    if !is_initialized {
        return nil, ErrInvalidArgument
    }
    
    ptr := heap_alloc_aligned(size, align)
    if ptr == null {
        return nil, ErrOutOfMemory
    }
    
    return ptr, nil
}

// Zero-fill allocated memory
func KAllocZero(size: usize) -> (?*byte, !KernelError) {
    ptr, err := KAlloc(size)?
    if err != nil {
        return nil, err
    }
    
    if ptr != nil {
        memset(ptr, 0, size)
    }
    
    return ptr, nil
}

// Copy memory
func KMemcpy(dest: *byte, src: *byte, n: usize) {
    memcpy(dest, src, n)
}

// Set memory
func KMemset(s: *byte, c: int, n: usize) {
    memset(s, c, n)
}

// Compare memory
func KMemcmp(s1: *byte, s2: *byte, n: usize) -> int {
    return memcmp(s1, s2, n)
}

// Get current kernel configuration
func GetKernelConfig() -> KernelConfig {
    return kernel_config
}

// Get memory layout
func GetMemoryLayout() -> MemoryLayout {
    return memory_layout
}

// Panic function for kernel
func KPanic(message: string) -> ! {
    // Disable interrupts
    disable_interrupts()
    
    // Print panic message
    kprintf("KERNEL PANIC: %s\n", message)
    
    // Print stack trace if available
    print_stack_trace()
    
    // Halt the system
    halt()
}

// Kernel printf for debugging
func KPrintf(format: string, args: ...any) {
    kprintf_impl(format, args...)
}

// Critical section management
type SpinLock struct {
    locked: bool
    cpu_id: uint32
}

func NewSpinLock() -> SpinLock {
    return SpinLock{locked: false, cpu_id: 0}
}

func (lock: *SpinLock) Lock() {
    disable_interrupts()
    while atomic_test_and_set(&lock.locked) {
        cpu_relax()
    }
    lock.cpu_id = get_cpu_id()
}

func (lock: *SpinLock) Unlock() {
    lock.cpu_id = 0
    atomic_store(&lock.locked, false)
    enable_interrupts()
}

func (lock: *SpinLock) IsLocked() -> bool {
    return atomic_load(&lock.locked)
}

// Atomic operations
func AtomicLoad32(ptr: *uint32) -> uint32 {
    return atomic_load_32(ptr)
}

func AtomicStore32(ptr: *uint32, val: uint32) {
    atomic_store_32(ptr, val)
}

func AtomicAdd32(ptr: *uint32, val: uint32) -> uint32 {
    return atomic_add_32(ptr, val)
}

func AtomicSub32(ptr: *uint32, val: uint32) -> uint32 {
    return atomic_sub_32(ptr, val)
}

func AtomicCompareAndSwap32(ptr: *uint32, old: uint32, new: uint32) -> bool {
    return atomic_cas_32(ptr, old, new)
}

func AtomicLoad64(ptr: *uint64) -> uint64 {
    return atomic_load_64(ptr)
}

func AtomicStore64(ptr: *uint64, val: uint64) {
    atomic_store_64(ptr, val)
}

func AtomicAdd64(ptr: *uint64, val: uint64) -> uint64 {
    return atomic_add_64(ptr, val)
}

func AtomicSub64(ptr: *uint64, val: uint64) -> uint64 {
    return atomic_sub_64(ptr, val)
}

func AtomicCompareAndSwap64(ptr: *uint64, old: uint64, new: uint64) -> bool {
    return atomic_cas_64(ptr, old, new)
}

