// Cache management
func FlushCache() {
    match current_platform.arch {
        case Architecture.X86_64:
            x86FlushCache()
        case Architecture.AArch64:
            armFlushCache()
        default:
            runtime.KPanic("Cache flush not supported on this platform")
    }
}

func InvalidateCache() {
    match current_platform.arch {
        case Architecture.X86_64:
            x86InvalidateCache()
        case Architecture.AArch64:
            armInvalidateCache()
        default:
            runtime.KPanic("Cache invalidate not supported on this platform")
    }
}

func FlushTlb() {
    match current_platform.arch {
        case Architecture.X86_64:
            x86FlushTlb()
        case Architecture.AArch64:
            armFlushTlb()
        default:
            runtime.KPanic("TLB flush not supported on this platform")
    }
}

// Power management
func CpuIdle() {
    match current_platform.arch {
        case Architecture.X86_64:
            x86CpuIdle()
        case Architecture.AArch64:
            armCpuIdle()
        default:
            runtime.KPanic("CPU idle not supported on this platform")
    }
}

func CpuHalt() -> ! {
    match current_platform.arch {
        case Architecture.X86_64:
            x86CpuHalt()
        case Architecture.AArch64:
            armCpuHalt()
        default:
            runtime.KPanic("CPU halt not supported on this platform")
    }
}

