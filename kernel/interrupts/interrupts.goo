// Interrupt statistics
func GetInterruptStats() -> []InterruptStat {
    stats := make([]InterruptStat, 0, MAX_INTERRUPTS)
    
    for i := 0; i < MAX_INTERRUPTS; i++ {
        desc := &interrupt_table[i]
        if desc.handler != nil || desc.count > 0 {
            stats = append(stats, InterruptStat{
                irq: i,
                name: desc.name,
                count: desc.count,
                enabled: desc.enabled,
            })
        }
    }
    
    return stats
}

type InterruptStat struct {
    irq: int
    name: string
    count: uint64
    enabled: bool
}

// External functions implemented in assembly
extern func init_pic() -> !runtime.KernelError
extern func load_idt() -> !runtime.KernelError
extern func enable_irq(irq: int)
extern func disable_irq(irq: int)
extern func send_eoi(irq: int)
extern func get_cr2() -> uint64